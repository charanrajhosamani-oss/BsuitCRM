@using BSuit.API.Areas.Admin.Models
@model SubscriptionVM
@{
    Layout = "/Views/Shared/_AdminLayout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Subscription Management</h3>

    <span id="helpIcon" class="help-icon">?</span>
</div>

<!-- Hidden Help Content -->
<div id="subscriptionHelpContent" style="display:none;">
    <div class="p-2">
        <h6 class="text-primary mb-2">Subscription Help</h6>

        <p class="text-white mb-2">
            Manage subscription plans for tenants/customers.
        </p>

        <ul class="mb-0 ps-3">
            <li>Create subscription plans</li>
            <li>Edit pricing & duration</li>
            <li>Activate/Deactivate plans</li>
            <li>Delete unused plans</li>
            <li>Search plans quickly</li>
        </ul>
    </div>
</div>

<!-- Alerts -->
<div id="alertContainer">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }
</div>

<!-- Search + Actions -->
<div class="row align-items-center mb-3">

    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input name="Search"
                   value="@Model.Search"
                   placeholder="Search subscription..."
                   class="form-control me-2" />

            <button class="btn btn-primary">
                Search
            </button>
        </form>
    </div>

    <div class="col-md-4 text-end">
        <button type="button"
                onclick="location.reload();"
                class="btn btn-secondary me-2">
            Refresh
        </button>

        <button type="button"
                onclick="showCreate()"
                class="btn btn-success">
            Add Plan
        </button>
    </div>
</div>

<!-- Table -->
<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Days</th>
            <th>Status</th>
            <th width="250">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr class="@(item.IsActive ? "" : "table-secondary text-muted")">
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.DurationInDays</td>
                <td>@(item.IsActive ? "Active" : "Inactive")</td>

                <td>
                    <button class="btn btn-primary btn-sm"
                            onclick="edit(@item.Id,'@item.Name',@item.Price,@item.DurationInDays)">
                        Edit
                    </button>

                    <form action="/Admin/Subscriptions/Toggle"
                          method="post"
                          style="display:inline">
                        <input type="hidden"
                               name="id"
                               value="@item.Id" />

                        <button class="btn btn-info btn-sm">
                            @(item.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>

                    <button onclick="del(@item.Id)"
                            class="btn btn-danger btn-sm">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="modal fade" id="subscriptionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitle">
                    Subscription Plan
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <form method="post" id="subscriptionForm">
                    <input type="hidden" name="Id" id="Id" />

                    <div class="mb-2">
                        <label>Name</label>
                        <input name="Name"
                               id="Name"
                               class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Price</label>
                        <input name="Price"
                               id="Price"
                               class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Duration (Days)</label>
                        <input name="DurationInDays"
                               id="DurationInDays"
                               class="form-control" />
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="submit"
                        form="subscriptionForm"
                        class="btn btn-success">
                    Save
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>
<script>
    let subscriptionModal;

    document.addEventListener("DOMContentLoaded", function () {

        subscriptionModal = new bootstrap.Modal(
            document.getElementById("subscriptionModal")
        );

        // Tooltip
        let helpContent =
            document.getElementById("subscriptionHelpContent").innerHTML;

        new bootstrap.Tooltip(
            document.getElementById("helpIcon"),
            {
                title: helpContent,
                html: true,
                placement: "left"
            }
        );

        // Auto-hide alerts
        let alertBox = document.getElementById("alertContainer");

        if (alertBox && alertBox.innerHTML.trim() !== "") {
            setTimeout(() => {
                alertBox.style.transition = "opacity 0.5s";
                alertBox.style.opacity = "0";

                setTimeout(() => {
                    alertBox.remove();
                }, 500);

            }, 3000);
        }
    });

    function showCreate() {
        document.getElementById("subscriptionForm").reset();
        document.getElementById("Id").value = "";
        document.getElementById("modalTitle").innerText = "Add Subscription";
        document.getElementById("subscriptionForm").action =
            "/Admin/Subscriptions/Create";

        subscriptionModal.show();
    }

    function edit(id, name, price, days) {
        document.getElementById("Id").value = id;
        document.getElementById("Name").value = name;
        document.getElementById("Price").value = price;
        document.getElementById("DurationInDays").value = days;

        document.getElementById("modalTitle").innerText = "Edit Subscription";
        document.getElementById("subscriptionForm").action =
            "/Admin/Subscriptions/Edit";

        subscriptionModal.show();
    }

    function del(id) {
        if (confirm("Delete this subscription plan?")) {

            let f = document.createElement("form");
            f.method = "post";
            f.action = "/Admin/Subscriptions/Delete";

            let i = document.createElement("input");
            i.type = "hidden";
            i.name = "id";
            i.value = id;

            f.appendChild(i);
            document.body.appendChild(f);
            f.submit();
        }
    }
</script>