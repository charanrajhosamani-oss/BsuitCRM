@using BSuit.API.Areas.Admin.Models
@model TenantSubscriptionVM
@{
    Layout = "/Views/Shared/_AdminLayout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Tenant Subscription Management</h3>

    <div>
        <a href="/Admin/Tenants/Index"
           class="btn btn-secondary me-2">
            ← Back
        </a>

        <span id="helpIcon" class="help-icon">?</span>
    </div>
</div>

<!-- Help Content -->
<div id="subscriptionHelpContent" style="display:none;">
    <div class="p-2">
        <h6 class="text-primary mb-2">Subscription Help</h6>

        <p class="text-white mb-2">
            Manage tenant subscription plans and duration.
        </p>

        <ul class="mb-0 ps-3">
            <li>Assign plans to tenants</li>
            <li>Activate/Deactivate plans</li>
            <li>Delete subscriptions</li>
            <li>Track plan duration</li>
        </ul>
    </div>
</div>

<!-- Alerts -->
<div id="alertContainer">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }
</div>

<!-- Search + Actions -->
<div class="row align-items-center mb-3">

    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input name="Search"
                   value="@Model.Search"
                   placeholder="Search subscriptions..."
                   class="form-control me-2" />

            <button class="btn btn-primary">
                Search
            </button>
        </form>
    </div>

    <div class="col-md-4 text-end">
        <button type="button"
                onclick="location.reload()"
                class="btn btn-secondary me-2">
            Refresh
        </button>

        <button type="button"
                onclick="showCreate()"
                class="btn btn-success">
            Assign Subscription
        </button>
    </div>
</div>

<!-- Grid -->
<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Tenant</th>
            <th>Plan</th>
            <th>Start Date</th>
            <th>End Date</th>         
            <th width="220">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr class="@(item.IsActive ? "" : "table-secondary text-muted")">

                <td>@item.Tenant?.Name</td>
                <td>@item.Subscription?.Name</td>
                <td>@item.StartDate.ToString("dd-MMM-yyyy")</td>
                <td>@item.EndDate.ToString("dd-MMM-yyyy")</td> 
                <td>
                    <form action="/Admin/TenantSubscriptions/Toggle"
                          method="post"
                          style="display:inline">
                        <input type="hidden"
                               name="id"
                               value="@item.Id" />

                        <button class="btn btn-warning btn-sm">
                            @(item.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>

                    <button onclick="del(@item.Id)"
                            class="btn btn-danger btn-sm">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="mt-3 d-flex flex-wrap gap-2">
    @for (int i = 1; i <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
    {
        <a asp-route-PageNumber="@i"
           asp-route-Search="@Model.Search"
           class="btn btn-sm @(i == Model.PageNumber ? "btn-primary" : "btn-light")">
            @i
        </a>
    }
</div>

<!-- Bootstrap Modal -->
<div class="modal fade" id="subscriptionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    Assign Subscription
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <form method="post"
                      action="/Admin/TenantSubscriptions/Create"
                      id="subscriptionForm">

                    <div class="mb-3">
                        <label>Tenant</label>
                        <select name="tenantId"
                                class="form-select">
                            @foreach (var t in Model.Tenants)
                            {
                                <option value="@t.Id">
                                    @t.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Subscription Plan</label>
                        <select name="subscriptionId"
                                class="form-select">
                            @foreach (var s in Model.Subscriptions)
                            {
                                <option value="@s.Id">
                                    @s.Name (@s.DurationInDays days)
                                </option>
                            }
                        </select>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="submit"
                        form="subscriptionForm"
                        class="btn btn-success">
                    Save
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    let subscriptionModal;

    document.addEventListener("DOMContentLoaded", function () {

        subscriptionModal = new bootstrap.Modal(
            document.getElementById("subscriptionModal")
        );

        // Help Tooltip
        let helpContent =
            document.getElementById("subscriptionHelpContent").innerHTML;

        new bootstrap.Tooltip(
            document.getElementById("helpIcon"),
            {
                title: helpContent,
                html: true,
                placement: "left"
            }
        );

        // Auto-hide alerts
        let alertBox = document.getElementById("alertContainer");

        if (alertBox && alertBox.innerHTML.trim() !== "") {
            setTimeout(() => {
                alertBox.style.transition = "opacity 0.5s";
                alertBox.style.opacity = "0";

                setTimeout(() => {
                    alertBox.remove();
                }, 500);
            }, 3000);
        }
    });

    function showCreate() {
        subscriptionModal.show();
    }

    function del(id) {
        if (!confirm("Delete this subscription?"))
            return;

        let form = document.createElement("form");
        form.method = "post";
        form.action = "/Admin/TenantSubscriptions/Delete";

        let input = document.createElement("input");
        input.type = "hidden";
        input.name = "id";
        input.value = id;

        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
    }
</script>