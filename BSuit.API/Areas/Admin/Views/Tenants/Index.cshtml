@using BSuit.API.Areas.Admin.Models
@using BSuit.Identity

@model TenantVM

@{
    Layout = "/Views/Shared/_AdminLayout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Tenant Management</h3>
    <span id="helpIcon" class="help-icon">?</span>
</div>

<!-- Help -->
<div id="tenantHelpContent" style="display:none;">
    <div class="p-2">
        <h6 class="text-primary mb-2">Tenant Management Help</h6>

        <p class="text-white mb-2">
            Manage tenant onboarding and access setup.
        </p>

        <ul class="mb-0 ps-3">
            <li>Create tenants</li>
            <li>Create tenant login credentials</li>
            <li>Assign subscriptions</li>
            <li>Manage modules</li>
            <li>Manage tenant users</li>
        </ul>
    </div>
</div>

<!-- Alerts -->
<div id="alertContainer">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
</div>

<!-- Search + Actions -->
<div class="row align-items-center mb-3">

    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input name="Search"
                   value="@Model.Search"
                   placeholder="Search tenants..."
                   class="form-control me-2" />

            <button class="btn btn-primary">
                Search
            </button>
        </form>
    </div>

    <div class="col-md-4 text-end">
        <button type="button"
                onclick="location.reload()"
                class="btn btn-secondary me-2">
            Refresh
        </button>
        
        @if (User.IsInRole(nameof(AppRoles.SUPERADMIN)))
        {
            <button type="button"
                    onclick="showCreate()"
                    class="btn btn-success">
                Add Tenant
            </button>
        }
        
    </div>
</div>

<!-- Grid -->
<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Domain</th>
            <th width="350">Tenant Actions</th>
            <th width="250">CRUD</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var t in Model.Items)
        {
            bool hasLogin = ViewBag.TenantHasLogin.Contains(t.Id);

            <tr class="@(t.IsActive ? "" : "table-secondary text-muted")">

                <td>@t.Name</td>
                <td>@t.Email</td>
                <td>@t.Domain</td>

                <td>
                    <button class="btn btn-primary btn-sm"
                            onclick="showLogin('@t.Id','@t.Email','@t.Name')"
                            @(hasLogin ? "disabled" : "")>
                        Login
                    </button>

                    <a href="@Url.Action("Index", "TenantSubscriptions", new { area = "Admin", tenantId = t.Id })"
                       class="btn btn-secondary btn-sm">
                        Plan
                    </a>

                    <a href="@Url.Action("Index", "TenantModules", new { area = "Admin", tenantId = t.Id })"
                       class="btn btn-dark btn-sm">
                        Modules
                    </a>

                    <a href="@Url.Action("Index", "TenantUsers", new { area = "Admin", tenantId = t.Id })"
                       class="btn btn-info btn-sm">
                        Users
                    </a>
                </td>

                <td>
                    <button class="btn btn-warning btn-sm"
                            onclick='edit(
                                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.Id)),
                                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.Name)),
                                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.Domain)),
                                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.Email))
                                )'>
                        Edit
                    </button>

                    <form action="/Admin/Tenants/Toggle"
                          method="post"
                          style="display:inline">
                        <input type="hidden" name="id" value="@t.Id" />

                        <button class="btn btn-info btn-sm">
                            @(t.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>

                    <button class="btn btn-danger btn-sm"
                            onclick="del('@t.Id')">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="mt-3 d-flex flex-wrap gap-2">
    @for (int i = 1; i <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
    {
        <a asp-route-PageNumber="@i"
           asp-route-Search="@Model.Search"
           class="btn btn-sm @(i == Model.PageNumber ? "btn-primary" : "btn-light")">
            @i
        </a>
    }
</div>

<!-- Tenant Modal -->
<div class="modal fade" id="tenantModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="tenantModalTitle">
                    Tenant
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <form method="post" id="tenantForm">
                    <input type="hidden" name="Id" id="Id" />

                    <input name="Name"
                           id="Name"
                           placeholder="Tenant Name"
                           class="form-control mb-2"
                           required />

                    <input name="Email"
                           id="Email"
                           placeholder="Email"
                           class="form-control mb-2" />

                    <input name="Domain"
                           id="Domain"
                           placeholder="Domain"
                           class="form-control mb-2" />
                </form>
            </div>

            <div class="modal-footer">
                <button type="submit"
                        form="tenantForm"
                        class="btn btn-success">
                    Save
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Login Modal -->
<div class="modal fade" id="loginModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">
                    Create Tenant Login
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <form method="post"
                      id="loginForm"
                      action="/Admin/Tenants/CreateLogin">

                    <input type="hidden"
                           name="TenantId"
                           id="LoginTenantId" />

                    <input name="Fullname"
                           id="Fullname"
                           class="form-control mb-2"
                           placeholder="Full Name"
                           required />

                    <input name="Email"
                           id="LoginEmail"
                           class="form-control mb-2"
                           placeholder="Email"
                           required />

                    <input name="Password"
                           id="LoginPassword"
                           type="password"
                           class="form-control mb-2"
                           placeholder="Password"
                           required />

                    <select name="Role"
                            id="LoginRole"
                            class="form-select mb-2">

                        @foreach (var role in ViewBag.Roles)
                        {
                            <option value="@role.Name">
                                @role.Name
                            </option>
                        }
                    </select>
                </form>
            </div>

            <div class="modal-footer">
                <button type="submit"
                        form="loginForm"
                        class="btn btn-success">
                    Create Login
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    let tenantModal;
    let loginModal;

    document.addEventListener("DOMContentLoaded", function () {

        tenantModal = new bootstrap.Modal(
            document.getElementById("tenantModal")
        );

        loginModal = new bootstrap.Modal(
            document.getElementById("loginModal")
        );

        // Tooltip
        let helpContent =
            document.getElementById("tenantHelpContent").innerHTML;

        new bootstrap.Tooltip(
            document.getElementById("helpIcon"),
            {
                title: helpContent,
                html: true,
                placement: "left"
            }
        );

        // Auto hide alerts
        let alertBox = document.getElementById("alertContainer");

        if (alertBox && alertBox.innerHTML.trim() !== "") {
            setTimeout(() => {
                alertBox.style.opacity = "0";
                alertBox.style.transition = "0.5s";

                setTimeout(() => {
                    alertBox.remove();
                }, 500);
            }, 3000);
        }
    });

    function showCreate() {
        document.getElementById("tenantForm").reset();
        document.getElementById("Id").value = "";

        document.getElementById("tenantForm").action =
            "/Admin/Tenants/Create";

        document.getElementById("tenantModalTitle").innerText =
            "Add Tenant";

        tenantModal.show();
    }

    function edit(id, name, domain, email) {
        document.getElementById("Id").value = id;
        document.getElementById("Name").value = name;
        document.getElementById("Domain").value = domain;
        document.getElementById("Email").value = email;

        document.getElementById("tenantForm").action =
            "/Admin/Tenants/Edit";

        document.getElementById("tenantModalTitle").innerText =
            "Edit Tenant";

        tenantModal.show();
    }

    function del(id) {
        if (!confirm("Delete this tenant?")) return;

        let f = document.createElement("form");
        f.method = "post";
        f.action = "/Admin/Tenants/Delete";

        let i = document.createElement("input");
        i.type = "hidden";
        i.name = "id";
        i.value = id;

        f.appendChild(i);
        document.body.appendChild(f);
        f.submit();
    }

    function showLogin(tenantId, email, fullName) {
        document.getElementById("LoginTenantId").value = tenantId;
        document.getElementById("LoginEmail").value = email;
        document.getElementById("Fullname").value = fullName;
        document.getElementById("LoginPassword").value = "";

        loginModal.show();
    }
</script>