@using BSuit.API.Areas.Admin.Models
@model BusinessMenuMasterVM

@{
    Layout = "/Views/Shared/_AdminLayout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>User Menus Management</h3>
    <span id="helpIcon" class="help-icon">?</span>
</div>

<!-- Help Content -->
<div id="paraHelpContent" style="display:none;">
    <div class="p-2">
        <h6 class="text-primary mb-2">User Menus Management Help</h6>

        <p class="text-white mb-2">
            Manage tenant's Users Menus.
        </p>

        <ul class="mb-0 ps-3">
            <li>Create Tenant's specific Menus Master</li>
            <li>Edit Menus details</li>
            <li>Activate/Deactivate Menus</li>
            <li>Delete Menus</li>
        </ul>
    </div>
</div>

<!-- Alerts -->
<div id="alertContainerT">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }
</div>

<!-- Search + Actions -->
<div class="row align-items-center mb-3">

    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input type="text"
                   name="Search"
                   value="@Model.Search"
                   placeholder="Search menus..."
                   class="form-control me-2" />

            <button class="btn btn-primary">
                Search
            </button>
        </form>
    </div>

    <div class="col-md-4 text-end">
        <button type="button"
                onclick="location.reload()"
                class="btn btn-secondary me-2">
            Refresh
        </button>

        <button type="button"
                onclick="showCreate()"
                class="btn btn-success">
            Add Menus
        </button>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>
                <a asp-route-SortColumn="Name"
                   asp-route-SortDirection="@(Model.SortColumn == "Name" && Model.SortDirection == "asc" ? "desc" : "asc")"
                   asp-route-Search="@Model.Search">
                    Name
                </a>
            </th>

            <th>
                <a asp-route-SortColumn="Url"
                   asp-route-SortDirection="@(Model.SortDirection == "asc" ? "desc" : "asc")"
                   asp-route-Search="@Model.Search">
                    URL
                </a>
            </th>
            <th>
                <a asp-route-SortColumn="SortOrder"
                   asp-route-SortDirection="@(Model.SortDirection == "asc" ? "desc" : "asc")"
                   asp-route-Search="@Model.Search">
                    Sort
                </a>
            </th>

            <th width="300">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var m in Model.Items)
        {
            <tr class="@(m.IsActive ? "" : "table-secondary text-muted")">
                <td><i class="@m.Icon"></i>&nbsp;@(m.ParentMenuId == 0 ? "-" : Model.Items.FirstOrDefault(x => x.Id == m.ParentMenuId)?.MenuName)&nbsp&nbsp;@m.MenuName</td>
                <td>@m.Url</td>

                <td>@m.SortOrder</td>

                <td>
                    <button type="button"
                            onclick='edit(
                                "@m.TenantId.ToString().ToLower()",
                                "@m.ModuleId",
                                "@m.Id",
                                "@Html.Raw(Uri.EscapeDataString(m.MenuName ?? ""))",
                                "@Html.Raw(Uri.EscapeDataString(m.Url ?? ""))",
                                "@Html.Raw(Uri.EscapeDataString(m.Icon ?? ""))",
                                "@m.ParentMenuId",
                                "@m.SortOrder"
                            )'
                            class="btn btn-warning btn-sm">
                        Edit
                    </button>

                    <button onclick="assign(@m.Id)" class="btn btn-primary btn-sm"
                            title="Redirects to Role Mapping page for assigning permissions to this menu">
                        Assign
                    </button>
                    <form action="/Admin/BusinessMenu/Toggle"
                          method="post"
                          style="display:inline">
                        <input type="hidden" name="id" value="@m.Id" />
                        <button class="btn btn-info btn-sm">
                            @(m.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>

                    <button onclick="del(@m.Id)" class="btn btn-danger btn-sm">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<!-- Pagination -->
<div class="mt-3 d-flex flex-wrap gap-2">
    @for (int i = 1; i <= totalPages; i++)
    {
        <form method="get" class="d-inline">
            <input type="hidden" name="PageNumber" value="@i" />
            <input type="hidden" name="Search" value="@Model.Search" />
            <input type="hidden" name="SortColumn" value="@Model.SortColumn" />
            <input type="hidden" name="SortDirection" value="@Model.SortDirection" />

            <button type="submit"
                    class="btn btn-sm @(i == Model.PageNumber ? "btn-primary" : "btn-light")">
                @i
            </button>
        </form>
    }
</div>



<!-- ALERT CONTAINER -->
<div id="alertContainerB" class="mt-2">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

</div>

<!-- BOOTSTRAP MODAL -->
<div class="modal fade" id="menuModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitle">Menu Management</h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form method="post" id="form">
                    <input type="hidden" name="Id" id="Id" />

                    @if (Model.IsSuperAdmin == true)
                    {
                        <div class="mb-2">
                            <label class="form-label">Tenant</label>
                            <select name="TenantId" id="TenantId" class="form-select">
                                <option value="0">-- Tenant --</option>
                                @foreach (var p in Model.Tenants)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden"
                               name="TenantId"
                               value="@Model.TenantId" />
                    }

                    <div class="mb-2">
                        <label class="form-label">Module</label>
                        <select name="ModuleId" id="ModuleId" class="form-select">
                            <option value="0">-- Module --</option>
                            @foreach (var p in Model.Modules)
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Parent Menu</label>
                        <select name="ParentMenuId" id="ParentMenuId" class="form-select">
                            <option value="0">-- No Parent --</option>
                            @foreach (var p in Model.Items.Where(x => x.ParentMenuId == 0))
                            {
                                <option value="@p.Id">@p.MenuName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Menu Name</label>
                        <input name="MenuName" id="MenuName"
                               placeholder="Menu Name"
                               class="form-control"
                               required />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">URL</label>
                        <input name="Url" id="Url"
                               placeholder="/Lead/Dashboard"
                               class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Icon</label>
                        <input name="Icon" id="Icon"
                               placeholder="fa fa-home"
                               class="form-control" />
                    </div>



                    <div class="mb-2">
                        <label class="form-label">Sort Order</label>
                        <input name="SortOrder"
                               id="SortOrder"
                               class="form-control" />
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="submit"
                        form="form"
                        class="btn btn-success">
                    Save
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>
<script>
    let menuModal;

    document.addEventListener("DOMContentLoaded", function () {
        menuModal = new bootstrap.Modal(document.getElementById('menuModal'));
    });

    function showCreate() {
        document.getElementById("form").reset();

        document.getElementById("Id").value = "";
        document.getElementById("modalTitle").innerText = "Add Menu";

        document.getElementById("form").action = "/Admin/BusinessMenu/Create";

        menuModal.show();
    }

    function edit(tenantId, moduleId, id, name, url, icon, parent, sort) {

        //document.getElementById("TenantId").value = tenantId || "";
        const tenantDropdown = document.getElementById("TenantId");
        if (tenantDropdown) {
            const tenantValue = (tenantId || "").toLowerCase();
            const option = [...tenantDropdown.options]
                .find(o => o.value.toLowerCase() === tenantValue);
            if (option) {
                option.selected = true;
            }
        }

        document.getElementById("ModuleId").value = moduleId || 0;
        document.getElementById("Id").value = id || 0;

        document.getElementById("MenuName").value = decodeURIComponent(name || "");
        document.getElementById("Url").value = decodeURIComponent(url || "");
        document.getElementById("Icon").value = decodeURIComponent(icon || "");

        document.getElementById("ParentMenuId").value = parent || 0;
        document.getElementById("SortOrder").value = sort || 0;

        document.getElementById("modalTitle").innerText = "Edit Menu";

        document.getElementById("form").action = "/Admin/BusinessMenu/Edit";

        menuModal.show();
    }

    function del(id) {
        if (confirm("Delete menu permanently?")) {

            let f = document.createElement("form");
            f.method = "post";
                f.action = "/Admin/BusinessMenu/Delete";

            let i = document.createElement("input");
            i.type = "hidden";
            i.name = "id";
            i.value = id;

            f.appendChild(i);
            document.body.appendChild(f);
            f.submit();
        }
    }

    function assign(id) {
            window.location.href = '/Admin/BusinessMenu/RoleMapping?MenuId=' + id;
    }
</script>
<script>
        document.addEventListener("DOMContentLoaded", function () {
            const alertBoxT = document.getElementById("alertContainerT");
            const alertBoxB = document.getElementById("alertContainerB");

            if (alertBoxT && alertBoxT.innerHTML.trim() !== "") {
                setTimeout(function () {

                    // Fade out effect
                    alertBoxT.style.transition = "opacity 0.5s ease";
                    alertBoxT.style.opacity = "0";

                    alertBoxB.style.transition = "opacity 0.5s ease";
                    alertBoxB.style.opacity = "0";

                    setTimeout(function () {
                        alertBoxT.style.display = "none";
                        alertBoxB.style.display = "none";

                        // Remove content from DOM
                        alertBoxT.innerHTML = "";
                        alertBoxB.innerHTML = "";
                    }, 500);

                }, 3000);
            }
        });

    document.addEventListener("DOMContentLoaded", function () {

        var helpContent = document.getElementById("paraHelpContent").innerHTML;

        new bootstrap.Tooltip(document.getElementById("helpIcon"), {
            title: helpContent,
            html: true,
            placement: "left"
        });

    });
</script>