    Layout = "~/Views/Shared/_StandardLayout.cshtml";
   
}

<link href="~/css/custom-new.css" rel="stylesheet" />
<!-- Flatpickr CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<style>
    /* Wrapper */
    .pagination-wrapper {
        position: relative;
        z-index: 10;
        background: #ffffff;
        border-radius: 14px;
        padding: 6px 10px;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
    }

    /* Pagination container spacing */
    .custom-pagination {
        gap: 6px;
    }

        /* Buttons */
        .custom-pagination .page-link {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid #e5e7eb; /* 👈 outline style */
            background: #ffffff;
            color: #6c757d;
            font-size: 15px;
            transition: all 0.25s ease;
        }

            /* Icon style (lighter feel) */
            .custom-pagination .page-link i {
                font-size: 16px;
                transition: transform 0.2s ease;
            }

            /* Hover effect */
            .custom-pagination .page-link:hover {
                z-index: 5;
                background: #0d6efd;
                border-color: #0d6efd;
                color: #ffffff;
                transform: translateY(-2px);
                box-shadow: 0 6px 16px rgba(13, 110, 253, 0.25);
            }

                /* Slight icon animation */
                .custom-pagination .page-link:hover i {
                    transform: scale(1.1);
                }

            /* Click effect */
            .custom-pagination .page-link:active {
                transform: scale(0.92);
                box-shadow: none;
            }

        /* Disabled */
        .custom-pagination .page-item.disabled .page-link {
            background: #f1f3f5;
            border-color: #e9ecef;
            color: #adb5bd;
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
        }

        /* Focus remove (clean UI) */
        .custom-pagination .page-link:focus {
            box-shadow: none;
        }

        /* Optional: smooth spacing for icons */
        .custom-pagination .page-link i {
            pointer-events: none;
        }
</style>

@functions {
    private string GetStageColor(string stage)
    {
        var colors = new[]
        {
            "#F4F8FF", // blue
            "#F3FBF5", // green
            "#FFF8F1", // orange
            "#FAF5FF", // purple
            "#F2FBFC", // cyan
            "#FFF4F7", // pink
            "#F7FAF0", // lime
            "#FFFDF5", // yellow
            "#F6F4FF", // lavender
            "#F2FAF8", // mint
            "#FFF6F3", // peach
            "#F5F7FF", // indigo
            "#FDECEC", // soft red
            "#EEF9FF", // sky
            "#F1FAF1", // soft green
            "#FFF1ED"  // soft peach
        };

        if (string.IsNullOrWhiteSpace(stage))
            return "#F5F7FF";

        // 🔥 Stable hash for consistent colors
        int hash = 0;

        foreach (char c in stage.ToLower())
        {
            hash += c;
        }

        int index = hash % colors.Length;

        return colors[index];
    }

    private string GetColor(string firstName, string lastName)
    {
        var colors = new[]
        {
            "#FBE4E4", // soft red
            "#FCE7F1", // soft pink
            "#F4E8FC", // soft violet
            "#EEE9FC", // soft purple
            "#E7ECFF", // soft indigo
            "#E5F4FF", // soft blue
            "#E4F7FF", // soft sky
            "#E5FCFB", // soft cyan
            "#E7F8F5", // soft teal
            "#EBF8EB", // soft green
            "#F2F8E5", // soft lime
            "#FFFBE5", // soft yellow
            "#FFF4DD", // soft amber
            "#FFF0E0", // soft orange
            "#FFECE5", // soft peach
            "#EEF2FF"  // pale indigo
        };

        int hash = (firstName + lastName).GetHashCode();
        int index = Math.Abs(hash) % colors.Length;

        return colors[index];
    }

    private string GetTabColor(string key)
    {
        var colors = new[]
        {
            "#EAF2FF", // light blue
            "#EAF8EE", // light green
            "#FFF2E8", // light orange
            "#F5ECFF", // light purple
            "#E8F8FA", // light cyan
            "#FFEAF1", // light pink
            "#F2F7E8", // light lime
            "#FFF9EA", // light yellow
            "#EFEAFF", // lavender
            "#EAF7F4", // mint
            "#FFF0EB", // peach
            "#EEF2FF"  // pale indigo
        };

        int hash = key.GetHashCode();
        int index = Math.Abs(hash) % colors.Length;

        return colors[index];
    }

}

