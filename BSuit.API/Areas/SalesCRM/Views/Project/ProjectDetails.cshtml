</div>
@section Scripts{

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        $(document).ready(function () {

            var activeTab = '@TempData["ActiveTab"]';

            if (activeTab) {

                $('.nav-link[href="#' + activeTab + '"]').tab('show');

            }

            var openTaskPanel = '@TempData["OpenTaskPanel"]';

            if (openTaskPanel === 'true') {

                openTaskPanelFunction();

            }

        });

        function openTaskPanelFunction() {

            $("#taskFormPanel").show();

            $("#taskListSection")
                .removeClass("col-md-12")
                .addClass("col-md-8");
        }

        $(document).ready(function () {

        // ====================================
        // ACTIVE TAB
        // ====================================

        var activeTab = '@TempData["ActiveTab"]';

        if (activeTab) {

            $('.nav-link[href="#' + activeTab + '"]')
                .tab('show');
        }

        // =====================================
        // OPEN TASK PANEL
        // =====================================

        var openTaskPanelFlag =
            '@TempData["OpenTaskPanel"]';

        var isEditTask =
            '@TempData["EditTask"]';

        if (openTaskPanelFlag === 'true') {

            // EDIT MODE
            if (isEditTask === 'true') {

                openEditTaskPanel();
            }
            else {

                // ADD MODE
                openTaskPanel();
            }
        }

   

        // // ====================================
        // // OPEN MODULE PANEL
        // // ====================================
        var openModulePanelFlag =
            '@TempData["OpenModulePanel"]';

        var isEditModule =
            '@TempData["EditModule"]';

        if (openModulePanelFlag === 'true') {

            // EDIT MODE
            if (isEditModule === 'true') {

                openEditModulePanel();
            }
            else {

                // ADD MODE
                openModulePanel();
            }
        }

       

    });
    function openModulePanel() {

        $("#moduleFormPanel").show();

        $("#moduleListSection")
            .removeClass("col-md-12")
            .addClass("col-md-8");

        // ======================================
        // CLEAR FORM
        // ======================================

        $("#NewProjectModule_ProjectModuleId").val('');

        $("#NewProjectModule_ModuleName").val('');

        $("#NewProjectModule_Description").val('');

        $("#NewProjectModule_EstimatedHours").val('');

        // ======================================
        // TITLE
        // ======================================

        $("#moduleFormTitle")
            .text("Add Project Module");

        // ======================================
        // BUTTON
        // ======================================

        $("#moduleSubmitBtn")
            .text("Save Module");

        // ======================================
        // FORM ACTION
        // ======================================

        $("#moduleForm")
            .attr("action",
                "/SalesCRM/Project/CreateProjectModule");
    }

    // ======================================
    // EDIT MODULE PANEL
    // ======================================

    function openEditModulePanel() {

        $("#moduleFormPanel").show();

        $("#moduleListSection")
            .removeClass("col-md-12")
            .addClass("col-md-8");

        // ======================================
        // TITLE
        // ======================================

        $("#moduleFormTitle")
            .text("Edit Project Module");

        // ======================================
        // BUTTON
        // ======================================

        $("#moduleSubmitBtn")
            .text("Update Module");

        // ======================================
        // FORM ACTION
        // ======================================

        $("#moduleForm")
            .attr("action",
                "/SalesCRM/Project/UpdateProjectModule");
    }

    function closeModulePanel() {

        document.getElementById("moduleFormPanel").style.display = "none";

        const list = document.getElementById("moduleListSection");

        list.classList.remove("col-md-8");
        list.classList.add("col-md-12");

        $("#moduleForm")[0].reset();

        $("#NewProjectModule_ProjectModuleId").val('');

    }

     function editModule(id) {

        window.location.href =
            '/SalesCRM/Project/EditProjectModule?id=' + id;
    }

    // =========================================
    // ADD TASK PANEL
    // =========================================

    function openTaskPanel() {

        $("#taskFormPanel").show();

        $("#taskListSection")
            .removeClass("col-md-12")
            .addClass("col-md-8");

        // =====================================
        // CLEAR FORM VALUES
        // =====================================

        $("#NewProjectTask_ProjectTaskId").val('');

        $("#NewProjectTask_TaskName").val('');

        $("#NewProjectTask_ProjectModuleId").val('');

        $("#NewProjectTask_AssignedTo").val('');

        $("#NewProjectTask_StartDate").val('');

        $("#NewProjectTask_DueDate").val('');

        $("#NewProjectTask_PriorityId").val('');

        $("#NewProjectTask_TaskStatusId").val('');

        $("#NewProjectTask_EstimatedHours").val('');

        $("#NewProjectTask_Description").val('');

        // =====================================
        // TITLE
        // =====================================

        $("#taskFormTitle")
            .text("Add Task");

        // =====================================
        // BUTTON
        // =====================================

        $("#taskSubmitBtn")
            .text("Save Task");

        // =====================================
        // FORM ACTION
        // =====================================

        $("#createTaskForm")
            .attr("action",
                "/SalesCRM/Project/CreateProject");
    }

    // =========================================
    // EDIT TASK PANEL
    // =========================================

    function openEditTaskPanel() {

        $("#taskFormPanel").show();

        $("#taskListSection")
            .removeClass("col-md-12")
            .addClass("col-md-8");

        // =====================================
        // TITLE
        // =====================================

        $("#taskFormTitle")
            .text("Edit Task");

        // =====================================
        // BUTTON
        // =====================================

        $("#taskSubmitBtn")
            .text("Update Task");

        // =====================================
        // FORM ACTION
        // =====================================

        $("#editTaskForm")
            .attr("action",
                "/SalesCRM/Project/UpdateProjectTask");
    }

    // =========================================
    // CLOSE PANEL
    // =========================================

    function closeTaskPanel() {

        $("#taskFormPanel").hide();

        $("#taskListSection")
            .removeClass("col-md-8")
            .addClass("col-md-12");

        // =====================================
        // CLEAR VALUES
        // =====================================

        $("#NewProjectTask_ProjectTaskId").val('');

        $("#NewProjectTask_TaskName").val('');

        $("#NewProjectTask_ProjectModuleId").val('');

        $("#NewProjectTask_AssignedTo").val('');

        $("#NewProjectTask_StartDate").val('');

        $("#NewProjectTask_DueDate").val('');

        $("#NewProjectTask_PriorityId").val('');

        $("#NewProjectTask_TaskStatusId").val('');

        $("#NewProjectTask_EstimatedHours").val('');

        $("#NewProjectTask_Description").val('');
    }

    </script>
}





