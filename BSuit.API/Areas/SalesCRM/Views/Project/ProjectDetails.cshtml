@using static BSuit.SalesCRM.Models.ProjectVM
@model ProjectAccount
@{
    Layout = "/Views/Shared/_StandardLayout.cshtml";
}
<style>
    .col-md-4 {
        position: sticky;
        top: 90px;
    }
</style>
<!-- TOP HEADER ACTION BAR -->
<div class="row mb-3">
    <div class="col-12">
        <div class="d-flex justify-content-end align-items-center p-3 shadow-sm bg-white rounded">

            <div class="d-flex gap-4">

                <a href="@Url.Action("ProjectTask", "Project", new { area = "SalesCRM", projectId = Model.ProjectId })"
                   class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-list-task me-1"></i> Project Tasks
                </a>

                <a href="@Url.Action("ProjectModules", "Project", new { area = "SalesCRM", projectId = Model.ProjectId })"
                   class="btn btn-outline-success btn-sm">
                    <i class="bi bi-box me-1"></i> Project Modules
                </a>

            </div>

        </div>
    </div>
</div>

<div class="row">

    <!-- ================= LEFT SIDE (ACCORDION) ================= -->
    <div class="col-md-7">

        <div class="accordion" id="projectAccordion">

            <!-- 🔹 PROJECT DETAILS -->
            <div class="accordion-item border-0">

                <!-- Edit Button -->
                <div class="d-flex justify-content-end mb-2">
                    <a class="btn btn-sm btn-primary"
                       href="@Url.Action("GetEditPartial", "Project", new { area = "SalesCRM", id = Model.ProjectId })">
                        <i class="bi bi-pencil-square me-1"></i> Edit
                    </a>
                </div>

                <h2 class="accordion-header">
                    <button class="accordion-button bg-white shadow-none fw-semibold text-warning"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#projectDetails"
                            aria-expanded="true">
                        Project Details
                    </button>
                </h2>

                <div id="projectDetails" class="accordion-collapse collapse show">
                    <div class="accordion-body">

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Project Name</div>
                            <div class="col-7 fw-medium">@Model.ProjectName</div>
                        </div>
                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Project Code</div>
                            <div class="col-7 fw-medium">@Model.ProjectCode</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Description</div>
                            <div class="col-7">@Model.Description</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Start Date</div>
                            <div class="col-7">@Model.StartDate?.ToString("dd-MMM-yyyy")</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">End Date</div>
                            <div class="col-7">@Model.EndDate?.ToString("dd-MMM-yyyy")</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Project Hours</div>
                            <div class="col-7">@Model.ProjectHours</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Balance Hours</div>
                            <div class="col-7">@Model.BalanceHours</div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- 🔹 ACCOUNT DETAILS -->
            <div class="accordion-item border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed bg-white shadow-none fw-semibold text-warning"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#accountDetails">
                        Account Details
                    </button>
                </h2>

                <div id="accountDetails" class="accordion-collapse collapse">
                    <div class="accordion-body">

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Account Name</div>
                            <div class="col-7">@Model.AccountName</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Company</div>
                            <div class="col-7">@Model.CompanyName</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Phone</div>
                            <div class="col-7">@Model.Phone</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Website</div>
                            <div class="col-7">
                                <a href="@Model.Website" target="_blank">@Model.Website</a>
                            </div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">City</div>
                            <div class="col-7">@Model.City</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">State</div>
                            <div class="col-7">@Model.State</div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Address</div>
                            <div class="col-7">@Model.Address</div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- 🔹 TEAM DETAILS -->
            <div class="accordion-item border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed bg-white shadow-none fw-semibold text-warning"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#projectTeam">
                        Team Details
                    </button>
                </h2>

                <div id="projectTeam" class="accordion-collapse collapse">
                    <div class="accordion-body">

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Project Manager</div>
                            <div class="col-7">
                                @Model.ProjectManagerName<br />
                                <small class="text-muted">@Model.ProjectManagerEmail</small>
                            </div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Project Supervisor</div>
                            <div class="col-7">
                                @Model.ProjectSupervisorName<br />
                                <small class="text-muted">@Model.ProjectSupervisorEmail</small>
                            </div>
                        </div>

                        <div class="row border-bottom py-2">
                            <div class="col-5 text-muted">Primary Resource</div>
                            <div class="col-7">
                                @Model.PrimaryResourceName<br />
                                <small class="text-muted">@Model.PrimaryResourceEmail</small>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>

    </div>


    <!-- ================= RIGHT SIDE (TASK CARD) ================= -->
    <div class="col-md-5">

        <div class="card shadow-sm">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-list-task me-1"></i> Project Tasks
                </span>
            </div>

            <div class="card-body p-2">

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">

                        <!-- ✅ HEADER ADDED -->
                        <thead class="table-light">
                            <tr>
                                <th>Project Task</th>
                                <th>Resource</th>
                                <th>Hours Allocated</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (ViewBag.Tasks != null && ViewBag.Tasks.Count > 0)
                            {
                                foreach (var item in ViewBag.Tasks)
                                {
                                    <tr>
                                        <td class="fw-semibold text-primary">
                                            @item.TaskName
                                        </td>
                                        <td class="small text-muted">
                                            @item.AssignedTo
                                        </td>
                                        <td>
                                            @item.EstimatedHours
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-3">
                                        No tasks
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

                <!-- View All -->
                <div class="text-center mt-2">
                    <a href="@Url.Action("ProjectTask", "Project", new { area = "SalesCRM", projectId = Model.ProjectId })"
                       class="text-primary small">
                        View All
                    </a>
                </div>

            </div>
        </div>

    </div>

