@using BSuit.SalesCRM.VM._Opportunity_
@model OpportunityListVM

@{
    ViewData["Title"] = "Opportunities";
    Layout = "/Views/Shared/_StandardLayout.cshtml";

    var selectedList = ViewBag.SelectedServices as string[] ?? new string[] { };

    int totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<style>

    .service-multi,
.choices {
    width: 350px !important;
}
</style>
<link href="~/css/custom-new.css" rel="stylesheet" />



<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4>Opportunities</h4>
    </div>

    <!-- STAGE TABS -->
    <div class="card border-0 shadow-sm mb-2">
        <div class="card-body py-2 px-2 d-flex align-items-center">

            <button type="button" class="btn btn-sm btn-light border me-2"
                    onclick="scrollTabs(-200)">
                <i class="fa fa-chevron-left"></i>
            </button>

            <div id="tabsContainer"
                 class="d-flex flex-nowrap overflow-auto flex-grow-1 gap-2">

                <button class="tab-btn @(string.IsNullOrEmpty(ViewBag.SelectedStage) ? "active" : "")"
                        onclick="changeStage('')">
                    All (@Model.TotalCount)
                </button>

                @foreach (var stage in ViewBag.Stages)
                {
                    var isActive = ViewBag.SelectedStage == stage.StageId.ToString();

                    <button class="tab-btn @(isActive ? "active" : "")"
                            onclick="changeStage('@stage.StageId')" desable>

                        @stage.StageName

                        <span class="badge @(isActive ? "active-badge" : "bg-secondary") ms-1">
                            @stage.Count
                        </span>
                    </button>
                }

            </div>

            <button type="button" class="btn btn-sm btn-light border ms-2"
                    onclick="scrollTabs(200)">
                <i class="fa fa-chevron-right"></i>
            </button>

        </div>
    </div>

     <!-- FILTER BAR -->
    <div class="card mb-3 shadow-sm border-0">
        <div class="card-body py-2 px-3">

            <form method="get">

                <input type="hidden" name="stageId" value="@ViewBag.SelectedStage" />

                <div class="d-flex align-items-center flex-wrap gap-2">

                    <!-- SEARCH -->
                    <input type="text"
                           name="searchText"
                           class="form-control form-control-sm"
                           placeholder="Search Opportunity..."
                           value="@ViewBag.SearchText"
                           style="width:220px;" />

                    <!-- FROM DATE -->
                    <input type="text"
                           name="startDate"
                           class="form-control form-control-sm datepicker"
                           placeholder="From Date"
                           value="@ViewBag.StartDate"
                           style="width:140px;" />

                    <!-- TO DATE -->
                    <input type="text"
                           name="endDate"
                           class="form-control form-control-sm datepicker"
                           placeholder="To Date"
                           value="@ViewBag.EndDate"
                           style="width:140px;" />

                    <!-- SERVICE MULTI SELECT -->
<select id="serviceIds"
        name="serviceIds"
        multiple
        class="form-select form-select-sm service-multi">

    @foreach (var item in (List<SelectListItem>)ViewBag.Services)
    {
        <option value="@item.Value"
                selected="@(selectedList.Contains(item.Value))">
            @item.Text
        </option>
    }

</select>

                    <!-- APPLY -->
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa fa-search"></i>
                    </button>

                    <!-- RESET -->
                    <a href="@Url.Action("OpportunityScoperView")"
                       class="btn btn-outline-danger btn-sm">
                        <i class="fa fa-refresh"></i>
                    </a>

                </div>

            </form>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">
    <div class="card-body p-0">

        <div class="table-container">

            <!-- SINGLE TABLE -->
            <div class="table-body-scroll">

<table class="table table-bordered align-middle mb-0 lead-table">
    <thead>
        <tr>
            <th style="width:60px;">Sl.No</th>
            <th>Opportunity</th>
            <th>Customer Id</th>
            <th>Client Name</th>
            <th>Service</th>
            <th>Scoper</th>
            <th>Sales Executive</th>
            <th>Created On</th>
            <th>Estimated On</th>
                        <th>Stage</th>

            <th> Status</th>
           
        </tr>
    </thead>

    <tbody>
        @{
            int count = (Model.PageNumber - 1) * Model.PageSize + 1;
        }

        @foreach (var item in Model.Opportunities)
        {
            <tr>
                <!-- Serial No -->
                <td class="text-center">@count</td>

                <!-- Opportunity -->
                <td>
       @if (item.ApprovalStatus == "Approved")
    {
       
                                                               <a href="@Url.Action("OpportunityDetails", new { id = item.OpportunityId, serviceId = item.ServiceId})"
                       class="text-decoration-none fw-semibold text-primary">
                        @item.OpportunityName
                    </a>
                                        }
                                        else
                                        {
                   <a href="@Url.Action("EditOpportunity", new { 
        id = item.OpportunityId, 
        serviceId = item.ServiceId,
        ApprovalStatus = item.ApprovalStatus
    })"
   class="text-decoration-none fw-semibold text-primary">

    @item.OpportunityName
</a>
                                        }

                     
                    
                </td>

                <td>@item.CustomerId</td>
                <td>@item.LeadName</td>
                <td>@item.ServiceName</td>

                <!-- Stage -->
              
                 <td>@item.Scoper</td>
                <td>@item.SlaesExecutive</td>

                <td>@item.CreatedOn?.ToString("dd-MMM-yyyy HH:mm")</td>
                <td>@item.EstimatedOn?.ToString("dd-MMM-yyyy HH:mm")</td>
                  <td>
                    <span class="badge bg-primary">@item.OpportunityStage</span>
                </td>

               <td>
    @if (item.ApprovalStatus == "Approved")
    {
        <span class="badge bg-success">
            Approved by @item.ApprovedByName
            (@item.ApprovedRole)
        </span>
    }
    else if (item.ApprovalStatus == "Cancelled")
    {
        <span class="badge bg-danger">
            Rejected by @item.ApprovedByName
            (@item.ApprovedRole)
        </span>
    }
    else if (item.ApprovalStatus == "Pending")
    {
        <span class="badge bg-warning text-dark">
            Pending - @item.ApprovedRole
        </span>
    }
    else
    {
        <span class="badge bg-secondary">
            @item.ApprovalStatus
        </span>
    }
</td>
               
            </tr>

            count++;
        }
    </tbody>
</table>
    </div>
        </div>
    </div>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top bg-light">

        <div>Total: @Model.TotalCount</div>

        <ul class="pagination pagination-sm mb-0">

            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link"
                   href="@Url.Action("OpportunityScoperView", new {
                        pageNumber = Model.PageNumber - 1,
                        stageId = ViewBag.SelectedStage,
                        searchText = ViewBag.SearchText,
                        startDate = ViewBag.StartDate,
                        endDate = ViewBag.EndDate,
                        serviceIds = selectedList
                   })">
                    Prev
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       href="@Url.Action("OpportunityScoperView", new {
                            pageNumber = i,
                            stageId = ViewBag.SelectedStage,
                            searchText = ViewBag.SearchText,
                            startDate = ViewBag.StartDate,
                            endDate = ViewBag.EndDate,
                            serviceIds = selectedList
                       })">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.PageNumber == totalPages ? "disabled" : "")">
                <a class="page-link"
                   href="@Url.Action("OpportunityScoperView", new {
                        pageNumber = Model.PageNumber + 1,
                        stageId = ViewBag.SelectedStage,
                        searchText = ViewBag.SearchText,
                        startDate = ViewBag.StartDate,
                        endDate = ViewBag.EndDate,
                        serviceIds = selectedList
                   })">
                    Next
                </a>
            </li>

        </ul>

    </div>

</div>
</div>
<!-- JS -->
<link href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>




    <script>

function changeStage(stage) {
    const url = new URL(window.location.href);
    url.searchParams.set("stageId", stage);
    url.searchParams.set("pageNumber", 1);
    window.location.href = url.toString();
}

function scrollTabs(val) {
    document.getElementById("tabsContainer").scrollLeft += val;
}

document.addEventListener("DOMContentLoaded", function () {

    const el = document.getElementById("serviceIds");

    if (el) {
        new Choices(el, {
            removeItemButton: true,
            searchEnabled: true,
            shouldSort: false,
            placeholder: true,
            placeholderValue: "Select Services"
        });
    }

});

</script>