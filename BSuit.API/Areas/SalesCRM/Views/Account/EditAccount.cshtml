    <script>
        $(document).on("click", ".delete-btn", function () {

        if (!confirm("Are you sure you want to delete this record?")) {
        return;
        }

        let row = $(this).closest("tr");

        // SAFE VALUE FETCH (works for input OR td)
        let mobile = row.find(".mobile").val();
        if (mobile === undefined) {
        mobile = row.find(".mobile").text();
        }

        let fullName = row.find(".fullName").val();
        if (fullName === undefined) {
        fullName = row.find(".fullName").text();
        }

        let departmentName = row.find(".Department").val();
        if (departmentName === undefined) {
        departmentName = row.find(".Department").text();
        }

        let designationName = row.find(".designation").val();
        if (designationName === undefined) {
        designationName = row.find(".designation").text();
        }

        

        // normalize
        mobile = (mobile || "").trim();
        fullName = (fullName || "").trim();
        departmentName = (departmentName || "").trim();
        designationName = (designationName || "").trim();

        // ✅ If mobile is empty → delete row directly
        if (mobile === "") {
        row.remove();
        return;
        }

        $.ajax({
        url: '@Url.Action("DeleteContact", "Account", new { area = "SalesCRM" })',
        type: 'POST',
        data: { mobile: mobile },
        success: function (res) {
        if (res.success) {
        row.remove();
        } else {
        alert(res.message);
        }
        },
        error: function () {
        alert("Error occurred");
        }
        });

        });
    </script>