    <script>
        function addRowReferral() {
        let table = document
        .getElementById("referralTable")
        .getElementsByTagName('tbody')[0];

        let newRow = table.insertRow();

        newRow.innerHTML = `
        <td><input name="ReferredName[]" class="form-control" /></td>
        <td><input name="ReferredEmail[]" class="form-control" /></td>
       
        <td><input name="ReferredPhone[]" class="form-control" /></td>
        <td>
        <select name="StatusId[]" class="form-select">
        <option value="1">Active</option>
        <option value="0">Inactive</option>
        </select>
        </td>
        <td>
        <button type="button"
        class="btn btn-danger btn-sm remove-btn">
        <i class="fa fa-trash"></i>
        </button>



        </td>
        `;
        }
    </script>

    <script>
        $(document).on("click", ".remove-btn", function () {

        if (!confirm("Are you sure you want to delete this record?")) {
        return;
        }

        let row = $(this).closest("tr");

        // Get values correctly
        let referredName = row.find('input[name*="ReferredName"]').val();
        let referredEmail = row.find('input[name*="ReferredEmail"]').val();
        let referredPhone = row.find('input[name*="ReferredPhone"]').val();

        referredName = (referredName || "").trim();
        referredEmail = (referredEmail || "").trim();
        referredPhone = (referredPhone || "").trim();

        // If phone empty -> remove row only
        if (referredPhone === "") {
        row.remove();
        return;
        }

