        $.ajax({
        url: '@Url.Action("UpdateAccount", "Account", new { area = "SalesCRM" })',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,

        success: function (response) {
        if (response.success)
        {

        alert(response.message || "Update successfully");

        window.location.href = '@Url.Action("AccountList", "Account", new { area = "SalesCRM" })';
        } else {
        alert(response.message || "Error occurred");
        }
        },

        error: function () {
        alert("Server error occurred");
        }
        });

        });
    </script>

