<style>
    /* Wrapper */
    .pagination-wrapper {
        position: relative;
        z-index: 10;
        background: #ffffff;
        border-radius: 14px;
        padding: 6px 10px;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
    }

    /* Pagination container spacing */
    .custom-pagination {
        gap: 6px;
    }

        /* Buttons */
        .custom-pagination .page-link {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid #e5e7eb; /* 👈 outline style */
            background: #ffffff;
            color: #6c757d;
            font-size: 15px;
            transition: all 0.25s ease;
        }

            /* Icon style (lighter feel) */
            .custom-pagination .page-link i {
                font-size: 16px;
                transition: transform 0.2s ease;
            }

            /* Hover effect */
            .custom-pagination .page-link:hover {
                z-index: 5;
                background: #0d6efd;
                border-color: #0d6efd;
                color: #ffffff;
                transform: translateY(-2px);
                box-shadow: 0 6px 16px rgba(13, 110, 253, 0.25);
            }

                /* Slight icon animation */
                .custom-pagination .page-link:hover i {
                    transform: scale(1.1);
                }

            /* Click effect */
            .custom-pagination .page-link:active {
                transform: scale(0.92);
                box-shadow: none;
            }

        /* Disabled */
        .custom-pagination .page-item.disabled .page-link {
            background: #f1f3f5;
            border-color: #e9ecef;
            color: #adb5bd;
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
        }

        /* Focus remove (clean UI) */
        .custom-pagination .page-link:focus {
            box-shadow: none;
        }

        /* Optional: smooth spacing for icons */
        .custom-pagination .page-link i {
            pointer-events: none;
        }
</style>

