@functions {
    private string GetStageColor(string stage)
    {
        var colors = new[]
        {
            "#F4F8FF", // blue
            "#F3FBF5", // green
            "#FFF8F1", // orange
            "#FAF5FF", // purple
            "#F2FBFC", // cyan
            "#FFF4F7", // pink
            "#F7FAF0", // lime
            "#FFFDF5", // yellow
            "#F6F4FF", // lavender
            "#F2FAF8", // mint
            "#FFF6F3", // peach
            "#F5F7FF", // indigo
            "#FDECEC", // soft red
            "#EEF9FF", // sky
            "#F1FAF1", // soft green
            "#FFF1ED"  // soft peach
        };

        if (string.IsNullOrWhiteSpace(stage))
            return "#F5F7FF";

        // 🔥 Stable hash for consistent colors
        int hash = 0;

        foreach (char c in stage.ToLower())
        {
            hash += c;
        }

        int index = hash % colors.Length;

        return colors[index];
    }

    private string GetColor(string firstName, string lastName)
    {
        var colors = new[]
        {
            "#FBE4E4", // soft red
            "#FCE7F1", // soft pink
            "#F4E8FC", // soft violet
            "#EEE9FC", // soft purple
            "#E7ECFF", // soft indigo
            "#E5F4FF", // soft blue
            "#E4F7FF", // soft sky
            "#E5FCFB", // soft cyan
            "#E7F8F5", // soft teal
            "#EBF8EB", // soft green
            "#F2F8E5", // soft lime
            "#FFFBE5", // soft yellow
            "#FFF4DD", // soft amber
            "#FFF0E0", // soft orange
            "#FFECE5", // soft peach
            "#EEF2FF"  // pale indigo
        };

        int hash = (firstName + lastName).GetHashCode();
        int index = Math.Abs(hash) % colors.Length;

        return colors[index];
    }

    private string GetTabColor(string key)
    {
        var colors = new[]
        {
            "#EAF2FF", // light blue
            "#EAF8EE", // light green
            "#FFF2E8", // light orange
            "#F5ECFF", // light purple
            "#E8F8FA", // light cyan
            "#FFEAF1", // light pink
            "#F2F7E8", // light lime
            "#FFF9EA", // light yellow
            "#EFEAFF", // lavender
            "#EAF7F4", // mint
            "#FFF0EB", // peach
            "#EEF2FF"  // pale indigo
        };

        int hash = key.GetHashCode();
        int index = Math.Abs(hash) % colors.Length;

        return colors[index];
    }

}



