    <script>
        $("#btnSave").click(function (e) {

        e.preventDefault();
        let isValid = true;
        let errorMessages = [];

        // Clear old errors
        $(".error").text("");

        // Helper function
        function validateField(selector, errorSelector, message) {
        let value = $(selector).val();

        if (value == null || value.toString().trim() === "") {
        $(errorSelector).text(message);
        errorMessages.push(message);
        isValid = false;
        }
        }

        // Validations
        validateField("#AccountName", "#AccountName-error", "Account Name is required");

        validateField("#CompanyName", "#CompanyName-error", "Company Name is required");

        validateField("#ownerName", "#OwnerName-error", "Owner Name is required");

        validateField("#CustomerTypeID", "#CustomerTypeID-error", "Customer Type is required");

        validateField("#JobTitleId", "#JobTitleId-error", "Job Title is required");

        validateField("#GenderId", "#GenderId-error", "Gender is required");

        validateField("#AccountSourceId", "#AccountSourceId-error", "Account Source is required");

        validateField("#CustomerCategoryId", "#CustomerCategoryId-error", "Customer Category is required");

        validateField("#AccountCategorizationId", "#AccountCategorizationId-error", "Account Categorization is required");

        validateField("#HighPotentialStatus", "#HighPotentialStatus-error", "High Potential Status is required");

        validateField("#CountryId", "#CountryId-error", "Country is required");

        validateField("#RegionId", "#RegionId-error", "Continent is required");

        validateField("#IndustryId", "#IndustryId-error", "Industry is required");

        validateField("#CompanySizeId", "#CompanySizeId-error", "Company Size is required");

        validateField("#LeadSourceId", "#LeadSourceId-error", "Lead Source is required");

        // Show popup summary
        if (!isValid) {

        let list = "<ul style='text-align:left;'>";

        errorMessages.forEach(msg => {
        list += `<li>${msg}</li>`;
        });

        list += "</ul>";

        Swal.fire({
        icon: 'error',
        title: 'Please fix the following:',
        html: list
        });

        return;
        }


        var form = document.getElementById("accountForm");
