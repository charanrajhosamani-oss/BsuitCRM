<script>
    const defaultSignature = `
    <br/>
    <br/>
    <br/>
    <br/>
    <br/>
    <hr>
    <p style="font-size:13px;">
    Regards,<br>
    <strong>Dhirendra M</strong><br>
    Executive Admin Services
    </p>
    `;

    tinymce.init({
    selector: '#responseBody',
    height: 400,
    menubar: true,

    plugins: [
    'advlist', 'autolink', 'lists', 'link', 'image', 'charmap', 'preview', 'anchor',
    'searchreplace', 'visualblocks', 'code', 'fullscreen',
    'insertdatetime', 'media', 'table', 'emoticons', 'help', 'wordcount'
    ],

    toolbar:
    'undo redo | styleselect | bold italic underline | ' +
    'alignleft aligncenter alignright | bullist numlist | ' +
    'link image | code fullscreen',

    branding: false,

    setup: function (editor) {

    // ✅ Set signature only once
    editor.on('init', function () {
    if (!editor.getContent({ format: 'text' }).trim()) {
    editor.setContent(defaultSignature);
    }
    });

    }
    });
</script>
<script>

    // LOAD OPPORTUNITY TABLE

    function loadOpportunityList() {

    let accountId = $("#ancAccountId").data("accountid");

    $.ajax({
    url: '@Url.Action("GetOpportunityList", "Account", new { area = "SalesCRM" })',
    type: 'GET',
    data: { accountId: accountId },

    success: function (response) {

    let rows = "";

    if (response.length > 0) {

    $.each(response, function (i, opp) {

    rows += `
    <tr>
    <td>${opp.service || ''}</td>

    <td>
    <a href="/SalesCRM/Account/ViewAccount?id=${opp.opportunityId}&serviceId=${opp.serviceId}"
    class="text-decoration-none text-primary fw-semibold">
    ${opp.opportunityName || ''}
    </a>
    </td>

    <td>${opp.opportunityStatus || ''}</td>

    <td>${formatDate(opp.requestedOn)}</td>

    <td>${opp.scoper || ''}</td>

    <td>${formatDate(opp.submittedOn)}</td>

    <td>${opp.deliveryManager || ''}</td>

    <td>${formatDate(opp.approvedOn)}</td>
    </tr>
    `;
    });

    } else {

    rows = `
    <tr>
    <td colspan="8" class="text-center">
    No Data Available
    </td>
    </tr>
    `;
    }

    $("#opportunityTableBody").html(rows);
    },

    error: function () {
    alert("Failed to load data");
    }
    });
    }

    function formatDate(date) {

    if (!date)
    return '';

    let d = new Date(date);

    return d.toLocaleDateString('en-GB');
    }


    // DATE FORMAT FUNCTION
    function formatDate(dateString) {

    if (!dateString)
    return '';

    let date = new Date(dateString);

    return date.toLocaleDateString('en-GB');
    }


    $("#btnScoping").click(function (e) {

    e.preventDefault();

    let isValid = true;
    let errorMessages = [];

    $("#serviceId-error").text("");
    $("#opportunityName-error").text("");

    let serviceId = $("#serviceId").val();
    let opportunityName = ($("#opportunityName").val() || "").trim();
    let accountId = $("#ancAccountId").data("accountid");

    if (!serviceId) {
    $("#serviceId-error").text("Service is required.");
    errorMessages.push("Service is required.");
    isValid = false;
    }

    if (!opportunityName) {
    $("#opportunityName-error").text("Opportunity Name is required.");
    errorMessages.push("Opportunity Name is required.");
    isValid = false;
    }

    if (!accountId) {
    errorMessages.push("Account is missing.");
    isValid = false;
    }

    if (!isValid) {

    Swal.fire({
    icon: 'error',
    title: 'Please fix the following:',
    html: "<ul style='text-align:left;'><li>" + errorMessages.join("</li><li>") + "</li></ul>"
    });

    return;
    }

    let formData = new FormData();

    formData.append("ServiceId", serviceId);
    formData.append("OpportunityName", opportunityName);
    formData.append("ancAccountId", accountId);

    $.ajax({

    url: '@Url.Action("CreateOpportunity", "Account")',
    type: 'POST',
    data: formData,
    processData: false,
    contentType: false,

    success: function (response) {

    if (response.success) {

    Swal.fire({
    icon: 'success',
    title: 'Success',
    text: response.message
    });

    $("#opportunityName").val('');
    $("#serviceId").prop("selectedIndex", 0);

    // RELOAD TABLE
    loadOpportunityList();

    } else {

    Swal.fire("Error", response.message || "Something went wrong", "error");
    }
    },

    error: function () {

    Swal.fire("Error", "Save failed. Please try again.", "error");
    }
    });
    });

</script>

<script>

    document.addEventListener("DOMContentLoaded", function () {

    const uploadBtn = document.getElementById("btnUploadDocument");
    const fileInput = document.getElementById("documentFileInput");

    // 🔥 Safety check
    if (!uploadBtn || !fileInput)
    return;

    // 🔥 Upload button click
    uploadBtn.addEventListener("click", function () {

    fileInput.value = "";
    fileInput.click();

    });

    // 🔥 File selected
    fileInput.addEventListener("change", function () {

    const file = this.files[0];

    if (!file)
    return;

    const accountId = uploadBtn.getAttribute("data-accountId");

    console.log("accountId:", accountId);

    if (!accountId) {

    alert("AccountId Id not found");
    return;
    }

    // 🔥 Confirmation
    const isConfirmed = confirm("Are you sure you want to upload this document?");

    if (!isConfirmed)
    return;

    let formData = new FormData();

    formData.append("accountId", accountId);
    formData.append("file", file);

    // 🔥 Correct POST URL
    fetch('@Url.Action("UploadLeadDocument", "Account")', {

    method: 'POST',
    body: formData

    })
    .then(async response => {

    if (!response.ok) {

    const errorText = await response.text();

    console.error("Server Error:", errorText);

    throw new Error(errorText);
    }

    return response.json();

    })
    .then(data => {

    alert("Document uploaded successfully");

    location.reload();

    })
    .catch(error => {

    console.error("Upload Error:", error);

    alert("Upload failed");

    });

    });

    });

</script>


