<script>
function changeStage(stage) {
    const url = new URL(window.location.href);
    url.searchParams.set("selectedStage", stage);
    url.searchParams.set("pageNumber", 1);
    window.location.href = url.toString();
}

function scrollTabs(val) {
    document.getElementById("tabsContainer").scrollLeft += val;
}

// 🔥 SELECTION LOGIC
const toolbar = document.getElementById("actionToolbar");
const btnView = document.getElementById("btnView");
const btnEdit = document.getElementById("btnEdit");
const btnDelete = document.getElementById("btnDelete");

function getSelected() {
    return document.querySelectorAll(".row-checkbox:checked");
}

function updateToolbar() {
    const selected = getSelected();
    const count = selected.length;

    toolbar.style.display = count > 0 ? "flex" : "none";

    btnDelete.disabled = count === 0;
    btnView.disabled = count !== 1;
    btnEdit.disabled = count !== 1;

    document.querySelectorAll(".row-checkbox").forEach(cb => {
        cb.closest("tr").classList.toggle("table-active", cb.checked);
    });
}

document.querySelectorAll(".row-checkbox").forEach(cb => {
    cb.addEventListener("change", updateToolbar);
});

document.getElementById("selectAll").addEventListener("change", function () {
    document.querySelectorAll(".row-checkbox").forEach(cb => {
        cb.checked = this.checked;
    });
    updateToolbar();
});

btnView.addEventListener("click", () => {
    const id = getSelected()[0].value;
    window.location.href = `../SalesCRM/Lead/Details/${id}`;
});

btnEdit.addEventListener("click", () => {
    const id = getSelected()[0].value;
    window.location.href = `../SalesCRM/Lead/Edit/${id}`;
});

btnDelete.addEventListener("click", () => {
    const ids = Array.from(getSelected()).map(cb => cb.value);
    console.log("Delete IDs:", ids);
});

</script>                  

<script>

    $(document).ready(function () {

        $('#transferModal').on('show.bs.modal', function () {

            $.ajax({
                url: '@Url.Action("GetAccounOwners", "Account", new { area = "SalesCRM" })',
                type: 'GET',
                dataType: 'json',

                success: function (data) {

                    let dropdown = $('#accountOwnerId');

                    dropdown.empty();

                    dropdown.append('<option value="">-- Select --</option>');

                    $.each(data, function (i, item) {

                        dropdown.append(
                            `<option value="${item.id}">
                                ${item.name}
                            </option>`
                        );

                    });

                },

                error: function (xhr, status, error) {

                    console.log(error);
                    alert('Failed to load sales executives');

                }

            });

        });

    });

$("#btnSave").click(function (e) {
    console.log("clicked"); // 🔥 ADD THIS

    e.preventDefault();

    $("#accountOwnerId-error").text("");

    let accountOwnerId = $("#accountOwnerId").val();

    if (!accountOwnerId) {
        $("#accountOwnerId-error").text("Account owner is required.");
        return;
    }

    let selectedAccounts = [];

    $(".row-checkbox:checked").each(function () {
        selectedAccounts.push($(this).val());
    });

    if (selectedAccounts.length === 0) {
        $("#accountOwnerId-error").text("Please select at least one account.");
        return;
    }

    var updateUrl = '@Url.Action("UpdateAccountOwner", "Account", new { area = "SalesCRM" })';

    let formData = new FormData();
    formData.append("AccountOwnerId", accountOwnerId);

    selectedAccounts.forEach(id => {
        formData.append("AccountIds", id);
    });

    $.ajax({
        url: updateUrl,
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,

        success: function (response) {
            if (response && response.success) 
            {
              
                 $("#accountOwnerId-error").text("Account owner updated successfully");
                 window.location.reload(); // ✅ most common
            } 
           else
           {
                alert("Save failed");         // fixed syntax error
            }
        },

        error: function (xhr) {
            console.log(xhr.responseText);
            Swal.fire("Error", "Save failed. Please try again.", "error");
        }
    });
});

</script>