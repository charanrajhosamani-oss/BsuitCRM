<div class="card border-0 shadow-sm mb-2">
    <div class="card-body py-2 px-2 d-flex align-items-center">

        <!-- LEFT SCROLL -->
        <button type="button"
                class="btn btn-sm btn-light border me-2 tab-scroll-btn"
                onclick="scrollTabs(-200)">
            <i class="fa fa-chevron-left"></i>
        </button>

        <!-- TABS -->
             <div id="tabsContainer"
             class="d-flex flex-nowrap overflow-auto flex-grow-1 gap-2 tabs-scroll-container">

            <!-- ALL TAB -->
            @{
                var isAllActive = Model.SelectedStage == "All";
            }

            <!-- DYNAMIC STAGES -->
            @foreach (var stage in Model.StageCounts)
            {
                var isActive = stage.Key == Model.SelectedStage;

                <button class="tab-btn @(isActive ? "active" : "")"
                        onclick="changeStage('@stage.Key')">

                    <span>
