                                <div class="info-row">
                                    <div class="info-label">Name</div>
                                    <div class="info-value">@Model.FirstName @Model.LastName</div>
                                </div>
                                <div class="info-row">
                                    <div class="info-label">Gender</div>
                                    <div class="info-value">@Model.Gender</div>
                                </div>
                            </div>
                        </div>

                        <!-- 🔷 CONTACT -->
                        <div class="sub-card">
                            <div class="sub-card-header">📞 Contact Info</div>
                            <div class="sub-card-body">
