                                <div class="info-row"><div class="info-label">Stage</div><div class="info-value">@Model.LeadStage</div></div>
                                <div class="info-row"><div class="info-label">Assigned</div><div class="info-value">@Model.SalesExecutive</div></div>
                                <div class="info-row"><div class="info-label">Created</div><div class="info-value">@Model.LeadCreatedOn?.ToString("dd-MMM-yyyy")</div></div>
                            </div>
