@using BSuit.SalesCRM.VM.Lead
@model LeadInfo;
@{
    ViewData["Title"] = "Lead Comprehensive View";
    Layout = "/Views/Shared/_StandardLayout.cshtml";
    var lead = Model;
}
@functions {
    public string GetFileIcon(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName)?.ToLower();

        return ext switch
        {
            ".pdf" => "bi bi-file-earmark-pdf text-danger",
            ".xls" or ".xlsx" => "bi bi-file-earmark-excel text-success",
            ".doc" or ".docx" => "bi bi-file-earmark-word text-primary",
            ".zip" => "bi bi-file-earmark-zip text-warning",
            _ => "bi bi-file-earmark text-secondary"
        };
    }
}
<link href="~/css/custom-new.css" rel="stylesheet" />



<div class="crm-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <!-- Tabs -->
        <ul class="nav nav-tabs" id="crmTabs">
            <li class="nav-item">
                <a class="nav-link active" href="#tab-overview" data-bs-toggle="tab">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#tab-initial" data-bs-toggle="tab">Email Communication</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#tab-lead" data-bs-toggle="tab">Lead Details</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#tab-business" data-bs-toggle="tab">Business Enquiry</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#tab-documents" data-bs-toggle="tab">Documents</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#tab-activity" data-bs-toggle="tab">Lead Activity</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#tab-opportunities" data-bs-toggle="tab">Opportunities</a>
            </li>
