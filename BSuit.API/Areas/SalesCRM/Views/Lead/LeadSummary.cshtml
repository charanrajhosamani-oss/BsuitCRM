<script>

    document.getElementById("scopingForm")
    .addEventListener("submit", async function (e) {

    e.preventDefault();

    try {

    const btn =
    document.getElementById("btnScoping");

    btn.disabled = true;

    btn.innerHTML =
    '<i class="fa fa-spinner fa-spin"></i> Processing...';

    const form = e.target;

    const formData =
    new FormData(form);

    // ============================================
    // ADD LEAD ID
    // ============================================

    formData.append(
    "LeadId",
    "@Model.LeadId"
    );

    // ============================================
    // MULTI SELECT SERVICES
    // ============================================

    const selectedServices =
    Array.from(
    document.getElementById("serviceDropdown")
    .selectedOptions
    )
    .map(x => x.value)
    .filter(x => x !== "ALL");

    // REMOVE OLD VALUES
    formData.delete("ServiceIds");

    // ADD MULTIPLE VALUES
    selectedServices.forEach(x => {

    formData.append("ServiceIds", x);

    });

    // ============================================
    // API CALL
    // ============================================

    const response =
    await fetch(
    '@Url.Action("CreateOpportunity", "Lead", new { area = "SalesCRM" })',
    {
    method: 'POST',
    body: formData
    });

    const data =
    await response.json();

    // ============================================
    // SUCCESS
    // ============================================

    if (data.success) {

    alert("Scoping requested successfully");

    form.reset();

    location.reload();
    }
    else {

    alert(
    data.message ||
    "Failed to create opportunity"
    );
    }

    // ============================================
    // RESET BUTTON
    // ============================================

    btn.disabled = false;

    btn.innerHTML =
    '<i class="fa fa-paper-plane"></i> Submit';

    }
    catch (err) {

    console.error(err);

    alert("Error occurred");

    const btn =
    document.getElementById("btnScoping");

    btn.disabled = false;

    btn.innerHTML =
    '<i class="fa fa-paper-plane"></i> Submit';
    }

    });

</script>

<script>

    document.addEventListener("DOMContentLoaded", function () {

    const uploadBtn = document.getElementById("btnUploadDocument");
    const fileInput = document.getElementById("documentFileInput");

    // 🔥 Safety check
    if (!uploadBtn || !fileInput)
    return;

    // 🔥 Upload button click
    uploadBtn.addEventListener("click", function () {

    fileInput.value = "";
    fileInput.click();

    });

    // 🔥 File selected
    fileInput.addEventListener("change", function () {

    const file = this.files[0];

    if (!file)
    return;

    const leadId = uploadBtn.getAttribute("data-leadid");

    console.log("LeadId:", leadId);

    if (!leadId) {

    alert("Lead Id not found");
    return;
    }

    // 🔥 Confirmation
    const isConfirmed = confirm("Are you sure you want to upload this document?");

    if (!isConfirmed)
    return;

    let formData = new FormData();

    formData.append("leadId", leadId);
    formData.append("file", file);

    // 🔥 Correct POST URL
    fetch('@Url.Action("UploadLeadDocument", "Lead")', {

    method: 'POST',
    body: formData

    })
    .then(async response => {

    if (!response.ok) {

    const errorText = await response.text();

    console.error("Server Error:", errorText);

    throw new Error(errorText);
    }

    return response.json();

    })
    .then(data => {

    alert("Document uploaded successfully");

    location.reload();

    })
    .catch(error => {

    console.error("Upload Error:", error);

    alert("Upload failed");

    });

    });

    });

</script>


