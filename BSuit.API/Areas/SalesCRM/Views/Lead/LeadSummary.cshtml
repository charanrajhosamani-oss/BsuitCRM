                    else
                    {
                        <tr>

                            <td colspan="4"
                                class="text-center text-muted py-4">

                                <i class="bi bi-folder-x fs-4 d-block mb-1"></i>

                                No Activities Found

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    // =========================================
    // SAVE BUTTON
    // =========================================

