                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="3" class="text-center text-muted py-4">
                                                    <i class="bi bi-folder-x fs-4 d-block mb-1"></i>
                                                    No documents available
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>

                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Initial Response Tab -->
        <div class="tab-pane fade" id="tab-initial">
            <div class="section-card purple">

                <!-- HEADER -->
                <div class="section-header d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-envelope"></i> Initial Response
                    </div>
                </div>

                <div class="section-body">

                    <!-- Hidden -->
                    <input type="hidden" id="ParentEntityType" value="Lead" />
                    <input type="hidden" id="ParentEntityId" value="@Model.LeadId" />

                    <!-- TO -->
                    <div class="mb-2">
                        <label>To:</label>
                        <input type="text" id="toEmail" class="form-control"
                               placeholder="Enter emails (comma separated)" />
                    </div>

                    <!-- CC/BCC TOGGLE -->
                    <div class="mb-2">
                        <small class="text-primary" style="cursor:pointer;"
                               onclick="toggleCcBcc()">
                            + Add CC / BCC
                        </small>
                    </div>

                    <!-- CC -->
                    <div class="mb-2 d-none" id="ccContainer">
                        <label>CC:</label>
                        <input type="text" id="ccEmail" class="form-control"
                               placeholder="Enter CC emails (comma separated)" />
                    </div>

                    <!-- BCC -->
                    <div class="mb-2 d-none" id="bccContainer">
                        <label>BCC:</label>
                        <input type="text" id="bccEmail" class="form-control"
                               placeholder="Enter BCC emails (comma separated)" />
                    </div>

                    <!-- SUBJECT -->
                    <div class="mb-2">
                        <label>Subject:</label>
                        <input type="text" id="subject" class="form-control"
                               placeholder="Email subject" />
                    </div>

                    <!-- ATTACHMENTS -->
                    <div class="mb-2">
                        <label>Attachments:</label>
                        <input type="file" id="attachments" class="form-control" multiple />
                        <ul id="attachmentList" class="list-group mt-2"></ul>
                    </div>

                    <!-- BODY -->
                    <div class="mb-2">
                        <label>Body:</label>
                        <textarea id="responseBody" class="form-control" rows="8"></textarea>
                    </div>

                    <!-- ACTION -->
                    <div class="d-flex justify-content-end">
                        <button id="btnSend" class="btn btn-primary">
                            <i class="bi bi-send"></i> Send
                        </button>
                    </div>

                </div>
            </div>

            <!-- 🔷 HISTORY -->
            <div class="section-card mt-3">
                <div class="section-header">
                    <i class="bi bi-clock-history"></i> Response History
                </div>

                <div class="section-body">
                    <table class="table table-sm table-striped" id="historyTable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>To</th>
                                <th>Subject</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody class="text-center">
                            @if (Model.EmailHistory != null && Model.EmailHistory.Any())
                            {
                                foreach (var mail in Model.EmailHistory)
                                {
                                    <tr>
                                        <!-- Date -->
                                        <td>
                                            @(mail.SentDate?.ToString("dd-MMM-yyyy HH:mm") ?? "-")
                                        </td>

                                        <!-- To Emails -->
                                        <td>
                                            <span title="@mail.ToEmails">
                                                @(string.IsNullOrWhiteSpace(mail.ToEmails)
                                                    ? "-"
                                                    : mail.ToEmails)
                                            </span>

                                            @* Optional CC indicator *@
                                            @if (!string.IsNullOrWhiteSpace(mail.CcEmails))
                                            {
                                                <span class="badge bg-light text-dark ms-1" title="Has CC">
                                                    CC
                                                </span>
                                            }
                                        </td>

                                        <!-- Subject -->
                                        <td>
                                            <span title="@mail.Subject">
                                                @(string.IsNullOrWhiteSpace(mail.Subject)
                                                    ? "(No Subject)"
                                                    : (mail.Subject.Length > 50
                                                        ? mail.Subject.Substring(0, 50) + "..."
                                                        : mail.Subject))
                                            </span>
                                        </td>

                                        <!-- Status -->
                                        <td>
                                            <span class="badge
                                                @(mail.Status == "Sent" ? "bg-success" :
                                                                                                                                                                                            mail.Status == "Failed" ? "bg-danger" :
                                                                                                                                                                                            mail.Status == "Draft" ? "bg-warning text-dark" :
                                                                                                                                                                                            "bg-secondary")">
                                                @(mail.Status ?? "Unknown")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">
                                        <i class="bi bi-inbox"></i> No email history
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <script>
                            function toggleCcBcc() {
                                document.getElementById('ccContainer')?.classList.toggle('d-none');
                                document.getElementById('bccContainer')?.classList.toggle('d-none');
                            }

                            let selectedFiles = [];

                            const input = document.getElementById('attachments');
                            const list = document.getElementById('attachmentList');
                            const sendBtn = document.getElementById('btnSend');

                            // Handle file selection
                            input?.addEventListener('change', function () {
                                selectedFiles = selectedFiles.concat(Array.from(this.files));
                                this.value = '';
                                renderFileList();
                            });

                            function renderFileList() {
                                if (!list) return;

                                list.innerHTML = '';

                                selectedFiles.forEach((file, index) => {
                                    const li = document.createElement('li');
                                    li.className = 'list-group-item d-flex justify-content-between align-items-center';

                                    li.innerHTML = `<span>${file.name} (${Math.round(file.size / 1024)} KB)</span>`;

                                    const delBtn = document.createElement('button');
                                    delBtn.className = 'btn btn-sm btn-danger';
                                    delBtn.innerHTML = '<i class="bi bi-x"></i>';

                                    delBtn.onclick = () => {
                                        selectedFiles.splice(index, 1);
                                        renderFileList();
                                    };

                                    li.appendChild(delBtn);
                                    list.appendChild(li);
                                });
                            }

                            // 🔹 Send Email
                            sendBtn?.addEventListener('click', function () {

                                // 🔥 Disable button immediately
                                sendBtn.disabled = true;
                                sendBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Sending...';

                                const to = document.getElementById('toEmail')?.value;
                                const cc = document.getElementById('ccEmail')?.value;
                                const bcc = document.getElementById('bccEmail')?.value;
                                const subject = document.getElementById('subject')?.value;

                                let body = '';
                                if (window.tinymce && tinymce.get('responseBody')) {
                                    body = tinymce.get('responseBody').getContent();
                                } else {
                                    body = document.getElementById('responseBody')?.value || '';
                                }

                                if (!to) {
                                    alert("To email is required");

                                    // 🔁 Re-enable button
                                    sendBtn.disabled = false;
                                    sendBtn.innerHTML = '<i class="bi bi-send"></i> Send';

                                    return;
                                }

                                let formData = new FormData();

                                formData.append("To", to);
                                formData.append("CC", cc || '');
                                formData.append("BCC", bcc || '');
                                formData.append("Subject", subject || '');
                                formData.append("BodyHtml", body);
                                formData.append("ParentEntityType", "Lead");
                                formData.append("ParentEntityId", "@Model.LeadId");

                                selectedFiles.forEach(file => {
                                    formData.append("Attachments", file);
                                });

                                fetch('@Url.Action("SendEmail", "Lead", new { area = "SalesCRM" })', {
                                    method: 'POST',
                                    body: formData
                                })
                                .then(res => res.json())
                                .then(data => {

                                    if (data && data.success) {

                                        alert("Email sent successfully");
                                        location.reload(); // 🔥 Refresh page
                                        // 🔹 Reset safely
                                        const safeSet = (id) => {
                                            const el = document.getElementById(id);
                                            if (el) el.value = '';
                                        };

                                        safeSet('toEmail');
                                        safeSet('ccEmail');
                                        safeSet('bccEmail');
                                        safeSet('subject');

                                        if (window.tinymce && tinymce.get('responseBody')) {
                                            tinymce.get('responseBody').setContent('');
                                        }

                                        selectedFiles = [];
                                        renderFileList();

                                    } else {
                                        alert("Failed to send email");
                                    }
                                })
                                .catch(err => {
                                    console.error(err);
                                    alert("Error occurred");
                                })
                                .finally(() => {
                                    // 🔁 ALWAYS re-enable button
                                    sendBtn.disabled = false;
                                    sendBtn.innerHTML = '<i class="bi bi-send"></i> Send';
                                });
                            });
            </script>
        </div>


        <!-- Lead Details Tab -->
        <div class="tab-pane fade" id="tab-lead">
            <partial name="_LeadDetails" model="@lead" />
        </div>

        <!-- Business Enquiry Tab -->
        <div class="tab-pane fade" id="tab-business">
            <div class="section-card orange">
                <div class="section-header"><i class="bi bi-briefcase"></i>&nbsp;  Business Enquiry</div>
                <div class="section-body">
                    <div>
                        <strong>Client Selected Service:</strong>

                        @if (lead.SelectedServices != null && lead.SelectedServices.Any())
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                @foreach (var s in lead.SelectedServices)
                                {
                                    <span class="badge rounded-pill bg-light text-dark border service-tag">
                                        <i class="bi bi-check-circle me-1 text-primary"></i>
                                        @s.ServiceName
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted mt-2">
                                <i class="bi bi-info-circle me-1"></i> No Services Selected
                            </div>
                        }
                    </div>
                    <hr />
                    <p><strong>Description:</strong>@lead.RequirementDetails</p>
                </div>
            </div>
        </div>

        <!-- Documents Tab -->
        <div class="tab-pane fade" id="tab-documents">
            <div class="section-card red mt-3">

                <div class="section-header d-flex justify-content-between align-items-center">

                    <span>
                        <i class="bi bi-folder"></i>&nbsp; Documents
                    </span>

                </div>

                <div class="section-body">

                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th class="text-center">File Name</th>
                                    <th class="text-center">Uploaded On</th>
                                    <th class="text-center" width="120">Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (Model.LeadDocuments != null && Model.LeadDocuments.Any())
                                {
                                    foreach (var doc in Model.LeadDocuments)
                                    {
                                        <tr>
                                            <td>
                                                <i class="@GetFileIcon(doc.FileName)"></i>
                                                @doc.FileName
                                            </td>

                                            <td class="text-center">
                                                @doc.UploadedOn.ToString("dd-MMM-yyyy")
                                            </td>

                                            <td class="text-center">

                                                <a href="@doc.FilePath"
                                                       download
                                                       target="_blank"
                                                       class="btn btn-sm btn-outline-primary">

                                                    <i class="bi bi-download"></i>

                                                </a>

                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-4">
                                            <i class="bi bi-folder-x fs-4 d-block mb-1"></i>
                                            No documents available
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>

                </div>

            </div>
        </div>

        <!-- Lead Activity Tab -->
        <div class="tab-pane fade" id="tab-activity">
            <!-- ========================================= -->
<!-- ADD LEAD ACTIVITY -->
<!-- ========================================= -->

<div class="section-card red mt-3">

    <div class="section-header d-flex justify-content-between align-items-center">

        <span>
            <i class="bi bi-journal-plus"></i>&nbsp;
            Add Lead Activity
        </span>

                    <button type="button"
                            id="btnSaveLeadActivity"
