<div class="modal fade" id="rejectLeadModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    Reject Lead
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="rejectLeadId" />

                <!-- REASON -->
                <div class="mb-3">

                    <label class="form-label fw-semibold">
                        Reject Reason
                    </label>

                    <select class="form-select" id="rejectReason">

    <option value="">
        -- Select Reason --
    </option>

    @foreach (var item in Model.RejectReasonsList)
    {
        <option value="@item.Value">
            @item.Text
        </option>
    }

</select>

                </div>

                <!-- REMARKS -->
                <div>

                    <label class="form-label fw-semibold">
                        Remarks
                    </label>

                    <textarea class="form-control"
                              id="rejectRemarks"
                              rows="3"></textarea>

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-light"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button type="button"
                        class="btn btn-danger"
                        id="btnSubmitReject">

                    Submit

                </button>

            </div>

        </div>
    </div>
</div>
<script>

document.addEventListener("DOMContentLoaded", function () {

    flatpickr(".datepicker", {
        dateFormat: "d-M-Y",
        allowInput: true
    });

});

</script>
<script>
function changeStage(stage) {
    const url = new URL(window.location.href);
    url.searchParams.set("selectedStage", stage);
    url.searchParams.set("pageNumber", 1);
    window.location.href = url.toString();
}

function scrollTabs(val) {
    document.getElementById("tabsContainer").scrollLeft += val;
}

// 🔥 SELECTION LOGIC
const toolbar = document.getElementById("actionToolbar");
const btnView = document.getElementById("btnView");
const btnEdit = document.getElementById("btnEdit");
const btnDelete = document.getElementById("btnDelete");

function getSelected() {
    return document.querySelectorAll(".row-checkbox:checked");
}

function updateToolbar() {
    const selected = getSelected();
    const count = selected.length;

    toolbar.style.display = count > 0 ? "flex" : "none";

    btnDelete.disabled = count === 0;
    btnView.disabled = count !== 1;
    btnEdit.disabled = count !== 1;

    document.querySelectorAll(".row-checkbox").forEach(cb => {
        cb.closest("tr").classList.toggle("table-active", cb.checked);
    });
}

document.querySelectorAll(".row-checkbox").forEach(cb => {
    cb.addEventListener("change", updateToolbar);
});

document.getElementById("selectAll").addEventListener("change", function () {
    document.querySelectorAll(".row-checkbox").forEach(cb => {
        cb.checked = this.checked;
    });
    updateToolbar();
});

btnView.addEventListener("click", () => {
    const id = getSelected()[0].value;
    window.location.href = `../SalesCRM/Lead/Details/${id}`;
});

btnEdit.addEventListener("click", () => {
    const id = getSelected()[0].value;
    window.location.href = `../SalesCRM/Lead/Edit/${id}`;
});

btnDelete.addEventListener("click", () => {
    const ids = Array.from(getSelected()).map(cb => cb.value);
    console.log("Delete IDs:", ids);
});

</script>
<script>

    const btnReject = document.getElementById("btnReject");

    btnReject.addEventListener("click", function (e) {

        e.preventDefault();

        const selected = getSelected();

        // Validate selection
        if (selected.length !== 1) {

            alert("Please select one lead");

            return;
        }

        // Get selected LeadId
        const leadId = selected[0].value;

        // Set hidden field
        document.getElementById("rejectLeadId").value = leadId;

        // Open Bootstrap Modal
        const rejectModal = new bootstrap.Modal(
            document.getElementById("rejectLeadModal")
        );

        rejectModal.show();

    });

</script>
<script>

    document.getElementById("btnSubmitReject")
        .addEventListener("click", function () {

        const leadId = document
            .getElementById("rejectLeadId")
            .value;

        const rejectReasonId = document
            .getElementById("rejectReason")
            .value;

        const remarks = document
            .getElementById("rejectRemarks")
            .value;

        // Validation
        if (rejectReasonId === "") {

            alert("Please select reject reason");

            return;
        }

        $.ajax({

            url: '../SalesCRM/Lead/RejectLead',

            type: 'POST',

            data: {

                leadId: leadId,
                rejectReasonId: rejectReasonId,
                remarks: remarks
            },

            success: function (response) {

                if (response.success) {

                    // Close Modal
                    const modalElement =
                        document.getElementById('rejectLeadModal');

                    const modal =
                        bootstrap.Modal.getInstance(modalElement);

                    modal.hide();

                    alert("Lead rejected successfully");

                    location.reload();
                }
                else {

                    alert(response.message);
                }
            },

            error: function () {

                alert("Something went wrong");
            }

        });

    });

</script>

<script>

    document.getElementById("btnApproveLeadRejection")
        .addEventListener("click", function () {

        // Get selected lead ids
        const leadIds = Array.from(getSelected())
            .map(cb => cb.value);

        // Validation
        if (leadIds.length === 0) {

            alert("Please select atleast one lead");

            return;
        }

        // Confirmation
        const isConfirmed = confirm(
            "Are you sure you want to approve selected lead rejection(s)?"
        );

        if (!isConfirmed) {

            return;
        }

        $.ajax({

            url: '../SalesCRM/Lead/ApproveLeadRejection',

            type: 'POST',

            traditional: true,

            data: {

                leadIds: leadIds
            },

            success: function (response) {

                if (response.success) {

                    alert("Lead rejection approved successfully");

                    location.reload();
                }
                else {

                    alert(response.message);
                }
            },

            error: function () {

                alert("Something went wrong");
            }

        });

    });


    document.getElementById("btnPickLead")
        .addEventListener("click", function () {

        // Get selected lead ids
        const leadIds = Array.from(getSelected())
            .map(cb => cb.value);

        // Validation
        if (leadIds.length === 0) {

            alert("Please select atleast one lead");

            return;
        }

        // Confirmation
        const isConfirmed = confirm(
            "Are you sure you want to pick the selected leads?"
        );

        if (!isConfirmed) {

            return;
        }

        $.ajax({

            url: '../SalesCRM/Lead/AssignSalesExecutive',

            type: 'POST',

            traditional: true,

            data: {

                leadIds: leadIds
            },

            success: function (response) {

                if (response.success) {

                    alert("Lead picked successfully");

                    location.reload();
                }
                else {

                    alert(response.message);
                }
            },

            error: function () {

                alert("Something went wrong");
            }

        });

    });

</script>
<script>

    document.addEventListener("DOMContentLoaded", function () {

        const tabs = document.querySelectorAll(".rejection-subtab");

        tabs.forEach(tab => {

            tab.addEventListener("click", function () {

                tabs.forEach(x => {

                    x.classList.remove("active");
                    x.classList.remove("btn-warning");
                    x.classList.remove("btn-success");

                    if (x.dataset.type === "pending") {
                        x.classList.add("btn-outline-warning");
                    }
                    else {
                        x.classList.add("btn-outline-success");
                    }

                });

                const type = this.dataset.type;

                if (type === "pending") {

                    this.classList.remove("btn-outline-warning");
                    this.classList.add("btn-warning");

                    document.querySelectorAll(".pending-row")
                        .forEach(x => x.classList.remove("d-none"));

                    document.querySelectorAll(".approved-row")
                        .forEach(x => x.classList.add("d-none"));
                }
                else {

                    this.classList.remove("btn-outline-success");
                    this.classList.add("btn-success");

                    document.querySelectorAll(".pending-row")
                        .forEach(x => x.classList.add("d-none"));

                    document.querySelectorAll(".approved-row")
                        .forEach(x => x.classList.remove("d-none"));
                }

            });

        });

    });

</script>