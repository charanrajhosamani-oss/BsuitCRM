@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>BSuit Login</title>

    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/font-awesome.min.css" rel="stylesheet" />

    <style>

        body {
            margin: 0;
            padding: 0;
            background: #f4f7fb;
            font-family: 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }

        .login-wrapper {
            min-height: 100vh;
        }

        /* ========================================= */
        /* LEFT PANEL */
        /* ========================================= */

        .left-panel {

            background: linear-gradient(135deg, #0f172a, #1e293b);

            color: white;

            position: relative;

            overflow: hidden;
        }

            .left-panel::before {

                content: "";

                position: absolute;

                width: 500px;
                height: 500px;

                background: rgba(255,255,255,0.05);

                border-radius: 50%;

                top: -150px;
                right: -120px;
            }

            .left-panel::after {

                content: "";

                position: absolute;

                width: 350px;
                height: 350px;

                background: rgba(255,255,255,0.04);

                border-radius: 50%;

                bottom: -120px;
                left: -100px;
            }

        .brand-logo img {
            height: 55px;
        }

        .welcome-title {

            font-size: 3rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .welcome-title span {
            color: #38bdf8;
        }

        .welcome-desc {

            color: #cbd5e1;

            font-size: 1rem;

            line-height: 1.8;
        }

        /* ========================================= */
        /* RIGHT PANEL */
        /* ========================================= */

        .right-panel {
            background: #f8fafc;
        }

        .login-card {

            background: white;

            width: 100%;
            max-width: 450px;

            border-radius: 20px;

            padding: 40px;

            box-shadow: 0 10px 35px rgba(0,0,0,0.08);
        }

        .login-card h2 {

            font-weight: 700;

            color: #0f172a;
        }

        .login-card p {
            color: #64748b;
        }

        .form-control {

            height: 52px;

            border-radius: 12px;

            border: 1px solid #dbe2ea;

            padding-left: 15px;
        }

            .form-control:focus {

                border-color: #0ea5e9;

                box-shadow: none;
            }

        .btn-login {

            height: 52px;

            border-radius: 12px;

            background: linear-gradient(90deg, #0ea5e9, #2563eb);

            border: none;

            font-weight: 600;

            color: white;

            transition: 0.3s;
        }

            .btn-login:hover {

                transform: translateY(-1px);

                opacity: 0.95;
            }

        .captcha-box {

            border: 1px solid #dbe2ea;

            border-radius: 10px;

            overflow: hidden;

            height: 42px;
        }

        .captcha-input {
            height: 42px;
        }

        .fp-link {

            text-decoration: none;

            color: #2563eb;

            font-size: 14px;
        }

            .fp-link:hover {
                text-decoration: underline;
            }

        .bottom-text {

            color: #64748b;

            font-size: 14px;
        }

            .bottom-text a {

                color: #2563eb;

                text-decoration: none;

                font-weight: 600;
            }

        .eye-icon {

            position: absolute;

            top: 42px;
            right: 15px;

            cursor: pointer;

            color: #64748b;
        }

        @@media(max-width:991px) {

            .left-panel {
                display: none !important;
            }

            .login-card {
                padding: 30px;
            }
        }

    </style>

</head>

<body>

    <div class="container-fluid">

        <div class="row login-wrapper">

            <!-- ========================================= -->
            <!-- LEFT PANEL -->
            <!-- ========================================= -->

            <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center p-5 left-panel">

                <div class="brand-logo mb-5">
                    <img src="~/images/logo-white.png" />
                </div>

                <h1 class="welcome-title mb-4">
                    Smart Enterprise <br />
                    <span>Management Platform</span>
                </h1>

                <p class="welcome-desc mb-4">

                    Manage leads, projects, operations, approvals,
                    collaboration, customer engagement and reporting
                    from one centralized enterprise ecosystem.

                </p>

                <div class="mt-3">

                    <h5 class="fw-semibold mb-3">
                        Platform Highlights
                    </h5>

                    <ul class="list-unstyled lh-lg text-light">

                        <li>
                            <i class="fa fa-check-circle me-2"></i>
                            CRM & Lead Management
                        </li>

                        <li>
                            <i class="fa fa-check-circle me-2"></i>
                            Workflow Automation
                        </li>

                        <li>
                            <i class="fa fa-check-circle me-2"></i>
                            Real-time Analytics
                        </li>

                        <li>
                            <i class="fa fa-check-circle me-2"></i>
                            Secure Enterprise Access
                        </li>

                    </ul>

                </div>

            </div>

            <!-- ========================================= -->
            <!-- RIGHT PANEL -->
            <!-- ========================================= -->

            <div class="col-lg-6 d-flex align-items-center justify-content-center right-panel p-4">

                <div class="login-card">

                    <h2 class="mb-2">
                        Welcome Back
                    </h2>

                    <p class="mb-4">
                        Sign in to continue to BSuit Enterprise Portal
                    </p>

                    <form method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3"></div>

                        <!-- EMAIL -->

                        <div class="mb-3">

                            <label asp-for="Input.Email"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Input.Email"
                                   class="form-control"
                                   placeholder="Enter your email" />

                            <span asp-validation-for="Input.Email"
                                  class="text-danger"></span>

                        </div>

                        <!-- PASSWORD -->

                        <div class="mb-3 position-relative">

                            <label asp-for="Input.Password"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Input.Password"
                                   type="password"
                                   class="form-control pe-5"
                                   id="passwordInput"
                                   placeholder="Enter password" />

                            <span class="eye-icon"
                                  onclick="togglePassword()">

                                <i id="toggleIcon"
                                   class="fa fa-eye"></i>

                            </span>

                            <span asp-validation-for="Input.Password"
                                  class="text-danger"></span>

                        </div>

                        <!-- REMEMBER -->

                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <div class="form-check">

                                <input class="form-check-input"
                                       asp-for="Input.RememberMe" />

                                <label class="form-check-label"
                                       asp-for="Input.RememberMe">
                                </label>

                            </div>

                            <a asp-page="./ForgotPassword"
                               class="fp-link">

                                Forgot Password?

                            </a>

                        </div>

                        <!-- CAPTCHA -->

                        <div class="row mb-4">

                            <div class="col-7">

                                <div class="d-flex align-items-center gap-2">

                                    <div class="captcha-box">

                                        <img id="captchaImage"
                                             src="?handler=Captcha"
                                             style="height:42px;" />

                                    </div>

                                    <a href="javascript:void(0)"
                                       onclick="refreshCaptcha()">

                                        <i class="fa fa-refresh"></i>

                                    </a>

                                </div>

                            </div>

                            <div class="col-5">

                                <input asp-for="CaptchaInput"
                                       class="form-control captcha-input"
                                       placeholder="Captcha" />

                            </div>

                        </div>

                        <!-- BUTTON -->

                        <button type="submit"
                                class="btn btn-login w-100">

                            Sign In

                        </button>

                        <!-- FOOTER -->

                        <p class="text-center bottom-text mt-4 mb-0">

                            Need account access?

                            <a href="#">
                                Contact Administrator
                            </a>

                        </p>

                    </form>

                </div>

            </div>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>

        function togglePassword() {

            var passwordInput =
                document.getElementById("passwordInput");

            var toggleIcon =
                document.getElementById("toggleIcon");

            if (passwordInput.type === "password") {

                passwordInput.type = "text";

                toggleIcon.classList.remove("fa-eye");

                toggleIcon.classList.add("fa-eye-slash");
            }
            else {

                passwordInput.type = "password";

                toggleIcon.classList.remove("fa-eye-slash");

                toggleIcon.classList.add("fa-eye");
            }
        }

        function refreshCaptcha() {

            document.getElementById("captchaImage").src =
                "?handler=Captcha&t=" + new Date().getTime();

            document.getElementById("CaptchaInput").value = "";
        }

    </script>

</body>

</html>
