@using BSuit.Core.Entities
@model List<NotificationRecipient>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between">
            <h5>All Notifications</h5>

            <a href="/Notifications/MarkAllRead"
               class="btn btn-sm btn-primary">
                Mark All Read
            </a>
        </div>

        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Message</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            var iconClass = "";
                            var iconBgClass = "";
                            var cardBgClass = "";

                            switch (item.Notification.NotificationType)
                            {
                                case NotificationType.Success:
                                    iconClass = "bi bi-check-circle-fill";
                                    iconBgClass = "success-bg";
                                    cardBgClass = "success-light";
                                    break;

                                case NotificationType.Error:
                                    iconClass = "bi bi-x-circle-fill";
                                    iconBgClass = "error-bg";
                                    cardBgClass = "error-light";
                                    break;

                                case NotificationType.Warning:
                                    iconClass = "bi bi-exclamation-triangle-fill";
                                    iconBgClass = "warning-bg";
                                    cardBgClass = "warning-light";
                                    break;

                                case NotificationType.Info:
                                    iconClass = "bi bi-info-circle-fill";
                                    iconBgClass = "info-bg";
                                    cardBgClass = "info-light";
                                    break;

                                default:
                                    iconClass = "bi bi-bell-fill";
                                    iconBgClass = "default-bg";
                                    cardBgClass = "default-light";
                                    break;
                            }

                        <tr class="@(item.IsRead ? "" : "table-warning")">
                            <td>
                                <div class="d-flex align-items-center gap-2">

                                    <div class="notification-icon @iconBgClass" title="@item.Notification.NotificationType.ToString()">
                                        <i class="@iconClass"></i>
                                    </div>

                                    <span class="fw-semibold">
                                        @item.Notification.Title
                                    </span>

                                </div>
                            </td>

                            <td>
                                @(item.Notification.Message.Length > 80
                                                            ? item.Notification.Message.Substring(0, 80) + "..."
                                                            : item.Notification.Message)
                            </td>

                            <td>
                                @item.Notification.CreatedOn.ToString("dd-MMM-yyyy hh:mm tt")
                            </td>

                                <td>
                                    @if (item.IsRead)
                                    {
                                        <span class="badge bg-success">
                                            Read
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Unread
                                        </span>
                                    }
                                </td>

                                <td>
                                    <a href="/Notifications/Read/@item.Id"
                                       class="btn btn-sm btn-info">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="text-muted mb-2">
                    Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages
                    (@ViewBag.TotalRecords total notifications)

                </div>
                @if (ViewBag.TotalPages > 1)
                {
                    <nav class="mt-3">
                        <ul class="pagination justify-content-end">

                            <!-- Previous -->
                            @if (ViewBag.CurrentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       href="@Url.Action("ViewAll", new { page = ViewBag.CurrentPage - 1 })">
                                        Previous
                                    </a>
                                </li>
                            }

                            <!-- Page Numbers -->
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link"
                                       href="@Url.Action("ViewAll", new { page = i })">
                                        @i
                                    </a>
                                </li>
                            }

                            <!-- Next -->
                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       href="@Url.Action("ViewAll", new { page = ViewBag.CurrentPage + 1 })">
                                        Next
                                    </a>
                                </li>
                            }

                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center text-muted">
                    No notifications available
                </div>
            }
        </div>
    </div>
</div>