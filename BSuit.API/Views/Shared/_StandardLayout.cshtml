        window.addEventListener("beforeunload", function () {
            if (window.performance.navigation.type !== 1) {
                navigator.sendBeacon('/Home/LogoutOnTabClose');
            }
        });
    </script> *@

    
    <script>
         // 1. Capture Browser TimeZone 
        (function () {

            const timezone =
                Intl.DateTimeFormat().resolvedOptions().timeZone;

            fetch('/Home/SetTimeZone', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    timeZone: timezone
                })
            });

        })();
    </script>

    <script>

        function showLoader() {
            document.getElementById("globalLoader")
                .style.display = "block";
        }

        function hideLoader() {
            document.getElementById("globalLoader")
                .style.display = "none";
        }

        // -----------------------------
        // jQuery AJAX
        // -----------------------------
        $(document).ajaxStart(function () {
            showLoader();
        });

        $(document).ajaxStop(function () {
            hideLoader();
        });

        // -----------------------------
        // Form Submit
        // -----------------------------
        $(document).on("submit", "form", function () {

            const form = $(this);

            // avoid loader for GET search/filter forms if needed
            if (form.attr("method")?.toLowerCase() !== "get") {
                showLoader();
            }
        });

      

        // -----------------------------
        // Back Button / Page Restore
        // -----------------------------
        window.addEventListener("pageshow", function () {
            hideLoader();
        });

    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>