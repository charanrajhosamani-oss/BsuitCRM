        <div class="menu-item" onclick="toggleMenu(this)">
            <div class="menu">
                <i class="bi bi-globe menu-icon"></i>
                <span class="menu-name">Project</span>
            </div>
            <i class="bi bi-chevron-right arrow"></i>
        </div>
        <div class="submenu">
            <a asp-area="SalesCRM"
